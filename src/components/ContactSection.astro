---
import { UX_CONFIG } from '../utils/ux';
import SocialLinks from './SocialLinks.astro';
import CalEmbed from './CalEmbed.tsx';

const contactOptions = [
    {
        platform: 'LinkedIn',
        icon: '💼',
        url: 'https://www.linkedin.com/in/michael-shaw-clt/',
        description: 'Professional Network'
    },
    {
        platform: 'Email',
        icon: '✉️',
        url: 'mailto:michael@madezmedia.com',
        description: 'Business Inquiries'
    },
    {
        platform: 'GitHub',
        icon: '💻',
        url: 'https://github.com/madezmedia',
        description: 'Open Source Projects'
    }
];
---

<section id="contact" class="contact-section">
    <div class="contact-header">
        <h2 class="section-title">Let's Connect</h2>
        <p class="section-subtitle">Schedule, Collaborate, Innovate</p>
    </div>

    <div class="contact-container">
        <div class="contact-methods">
            <div class="quick-connect">
                {contactOptions.map((option) => (
                    <div 
                        class="connection-card" 
                        data-platform={option.platform}
                    >
                        <div class="connection-icon-container">
                            <span class="connection-icon">{option.icon}</span>
                        </div>
                        <div class="connection-details">
                            <h3 class="connection-platform">{option.platform}</h3>
                            <p class="connection-description">{option.description}</p>
                            <a 
                                href={option.url} 
                                target="_blank" 
                                rel="noopener noreferrer"
                                class="connection-link"
                            >
                                Connect
                            </a>
                        </div>
                    </div>
                ))}
            </div>

            <div class="social-connect">
                <h3 class="social-title">Follow My Journey</h3>
                <SocialLinks />
            </div>
        </div>

        <div class="scheduling-container">
            <div class="scheduling-header">
                <h3 class="scheduling-title">Book a Meeting</h3>
                <p class="scheduling-subtitle">Direct Access to Collaboration</p>
            </div>
            <CalEmbed client:load />
        </div>
    </div>
</section>

<style define:vars={{
    transitionDuration: `${UX_CONFIG.TRANSITION_DURATION}ms`
}}>
    .contact-section {
        max-width: 1200px;
        margin: 4rem auto;
        padding: 2.5rem;
        background: var(--bg-secondary);
        border-radius: 16px;
        border: 1px solid rgba(45, 74, 62, 0.08);
        box-shadow: 0 8px 32px rgba(45, 74, 62, 0.03);
        transition: transform var(--transitionDuration) ease;
    }

    .contact-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .section-title {
        font-size: 2.75rem;
        color: var(--primary);
        margin: 0;
        font-family: 'Playfair Display', serif;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.02em;
    }

    .section-subtitle {
        color: var(--accent-pink);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-top: 0.5rem;
    }

    .contact-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
    }

    .contact-methods {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .quick-connect {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .connection-card {
        background: var(--bg-primary);
        border-radius: 12px;
        border: 1px solid rgba(45, 74, 62, 0.06);
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        transition: 
            transform var(--transitionDuration) ease,
            box-shadow var(--transitionDuration) ease;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 12px rgba(45, 74, 62, 0.02);
    }

    .connection-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(
            circle at center, 
            color-mix(in srgb, var(--primary) 20%, transparent) 0%, 
            transparent 70%
        );
        opacity: 0;
        transition: opacity var(--transitionDuration) ease;
        z-index: 1;
    }

    .connection-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(45, 74, 62, 0.06);
    }

    .connection-card:hover::before {
        opacity: 0;
    }

    .connection-icon-container {
        background: var(--bg-secondary);
        width: 80px;
        height: 80px;
        border-radius: 10px;
        border: 1px solid rgba(45, 74, 62, 0.08);
        display: flex;
        justify-content: center;
        align-items: center;
        transition: transform var(--transitionDuration) ease;
    }

    .connection-card:hover .connection-icon-container {
        transform: rotate(15deg) scale(1.05);
    }

    .connection-icon {
        font-size: 2.5rem;
        opacity: 0.9;
    }

    .connection-details {
        flex-grow: 1;
    }

    .connection-platform {
        margin: 0 0 0.5rem;
        color: var(--primary);
        font-family: 'Playfair Display', serif;
        font-size: 1.3rem;
        font-weight: 700;
    }

    .connection-description {
        margin: 0 0 1rem;
        color: var(--text-primary);
        opacity: 0.8;
        font-size: 0.9rem;
    }

    .connection-link {
        display: inline-block;
        background: var(--primary);
        color: var(--bg-primary);
        padding: 0.5rem 1.5rem;
        text-decoration: none;
        border-radius: 9999px;
        border: 1px solid var(--primary);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.2s ease;
        box-shadow: 0 4px 10px rgba(45, 74, 62, 0.08);
    }

    .connection-link:hover {
        background: transparent;
        color: var(--primary);
        transform: translateY(-2px);
        box-shadow: 0 6px 14px rgba(45, 74, 62, 0.12);
    }

    .social-connect {
        text-align: center;
    }

    .social-title {
        color: var(--text-primary);
        margin-bottom: 1rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
    }

    .scheduling-container {
        background: var(--bg-primary);
        border-radius: 12px;
        border: 1px solid rgba(45, 74, 62, 0.06);
        padding: 2rem;
        box-shadow: 0 8px 24px rgba(45, 74, 62, 0.02);
    }

    .scheduling-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .scheduling-title {
        color: var(--primary);
        margin: 0;
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
    }

    .scheduling-subtitle {
        color: var(--accent-pink);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        text-transform: uppercase;
        margin-top: 0.5rem;
    }

    @media (max-width: 768px) {
        .contact-container {
            grid-template-columns: 1fr;
        }
    }
</style>
