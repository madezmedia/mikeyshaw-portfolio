---
interface BlogPost {
	title: string;
	excerpt: string;
	date: string;
	url: string;
	readingTime: string;
}

const blogPosts: BlogPost[] = [
	{
		title: "Building Repubot: A Journey in AI-Powered Reputation Management",
		excerpt: "Learn about the challenges and insights gained while developing an innovative reputation management solution.",
		date: "2024-04-15",
		url: "#",
		readingTime: "5 min read"
	},
	{
		title: "The Future of E-commerce: Trends to Watch in 2024",
		excerpt: "Exploring emerging technologies and strategies reshaping the e-commerce landscape.",
		date: "2024-04-10",
		url: "#",
		readingTime: "4 min read"
	},
	{
		title: "Leveraging AI for Better Customer Experience",
		excerpt: "How artificial intelligence is transforming customer service and engagement.",
		date: "2024-04-05",
		url: "#",
		readingTime: "6 min read"
	}
];

function formatDate(dateStr: string) {
	return new Date(dateStr).toLocaleDateString('en-US', {
		month: 'long',
		day: 'numeric',
		year: 'numeric'
	});
}
---

<div class="blog-feed-container">
	<h2 class="blog-section-title">Latest Intel & Dispatches</h2>
	<div class="posts-list">
		{blogPosts.map((post) => (
			<article class="blog-post-item">
				<div class="post-meta-data">
					<time datetime={post.date}>{formatDate(post.date)}</time>
					<span class="reading-time-badge">{post.readingTime}</span>
				</div>
				<h3 class="post-title">
					<a href={post.url}>{post.title}</a>
				</h3>
				<p class="post-excerpt">{post.excerpt}</p>
				<a href={post.url} class="read-more-link">
					Read Dispatch
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<line x1="5" y1="12" x2="19" y2="12"></line>
						<polyline points="12 5 19 12 12 19"></polyline>
					</svg>
				</a>
			</article>
		))}
	</div>
</div>

<style>
	.blog-feed-container {
		margin: 2rem 0;
		padding: 0;
	}

	.blog-section-title {
		font-family: "Playfair Display", serif;
		font-size: clamp(24px, 3vw, 36px);
		font-weight: 850;
		color: #2d4a3e;
		margin-bottom: 2.5rem;
		letter-spacing: -0.015em;
	}

	.posts-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.blog-post-item {
		padding: 2rem 0;
		border-bottom: 1px solid rgba(45, 74, 62, 0.08);
		transition: transform 0.3s ease;
	}

	.blog-post-item:last-child {
		border-bottom: none;
	}

	.post-meta-data {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-family: "JetBrains Mono", monospace;
		font-size: 11px;
		color: rgba(45, 74, 62, 0.5);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 0.75rem;
	}

	.reading-time-badge {
		padding-left: 0.75rem;
		border-left: 1px solid rgba(45, 74, 62, 0.2);
	}

	.post-title {
		font-family: "Playfair Display", serif;
		font-size: 1.5rem;
		font-weight: 800;
		line-height: 1.3;
		margin: 0 0 0.75rem 0;
		letter-spacing: -0.01em;
	}

	.post-title a {
		color: #2d4a3e;
		text-decoration: none;
		transition: opacity 0.2s ease;
	}

	.post-title a:hover {
		opacity: 0.7;
	}

	.post-excerpt {
		font-family: "Outfit", sans-serif;
		margin: 0 0 1.25rem 0;
		font-size: 0.95rem;
		color: rgba(45, 74, 62, 0.85);
		line-height: 1.6;
		max-width: 48rem;
	}

	.read-more-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: #2d4a3e;
		font-family: "Outfit", sans-serif;
		font-size: 13.5px;
		font-weight: 600;
		text-decoration: none;
		transition: gap 0.2s ease, opacity 0.2s ease;
	}

	.read-more-link:hover {
		gap: 0.6rem;
		opacity: 0.8;
	}

	.read-more-link svg {
		transition: transform 0.2s ease;
	}

	.read-more-link:hover svg {
		transform: translateX(2px);
	}
</style>