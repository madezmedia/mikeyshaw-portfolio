---
interface BlogPost {
	title: string;
	excerpt: string;
	date: string;
	url: string;
	readingTime: string;
}

const blogPosts: BlogPost[] = [
	{
		title: "ACMI Protocol v1.2: How We Built a Self-Organizing AI Fleet That Learns From Its Mistakes",
		excerpt: "A deep dive into our custom ACMI (Agentic Context Memory Interface) v1.2 atomic memory bus, synchronizing state, profiles, and event timelines across independent AI agent fleets.",
		date: "2026-04-29",
		url: "https://medium.com/@madezmedia/acmi-protocol-v1-2-how-we-built-a-self-organizing-ai-fleet-that-learns-from-its-mistakes-f76668dc2204",
		readingTime: "6 min read"
	},
	{
		title: "I Gave My 10 AI Agents a Shared Brain. Here’s Why, How, and Whether It Was Worth It.",
		excerpt: "For six months, our agent swarm coordination was a disaster. Here is why Postgres, Notion, and graph frameworks failed for multi-agent shared memory, and how Redis Sorted Sets solved it.",
		date: "2026-04-22",
		url: "https://medium.com/@madezmedia/i-gave-my-10-ai-agents-a-shared-brain-heres-why-how-and-whether-it-was-worth-it-943025021e5c",
		readingTime: "8 min read"
	},
	{
		title: "Unlocking Hidden Insights: How AI is Revolutionizing Data Analytics",
		excerpt: "Artificial intelligence in data analytics is not just a fleeting trend; it's an evolution in how we interpret and utilize data, paving the way for corporate growth and innovation.",
		date: "2024-06-19",
		url: "https://medium.com/@madezmedia/unlocking-hidden-insights-how-ai-is-revolutionizing-data-analytics-28d111b2b9a1",
		readingTime: "5 min read"
	},
	{
		title: "Best Practices for Integrating Zapier and ChatGPT for Automated Social Media Management",
		excerpt: "Streamline marketing and save time by linking ChatGPT prompts with Zapier webhooks to build automated content publication and feedback loops.",
		date: "2023-12-26",
		url: "https://medium.com/@madezmedia/best-practices-for-integrating-zapier-and-chatgpt-for-automated-social-media-management-cda59b8a853c",
		readingTime: "4 min read"
	}
];

function formatDate(dateStr: string) {
	return new Date(dateStr).toLocaleDateString('en-US', {
		month: 'long',
		day: 'numeric',
		year: 'numeric'
	});
}
---

<div class="blog-feed-container">
	<div class="blog-header">
		<h2 class="blog-section-title">Latest Intel & Dispatches</h2>
		<p class="blog-section-subtitle">Real-world AI systems architecture, protocols, and automation engineering logs</p>
	</div>
	<div class="posts-list">
		{blogPosts.map((post) => (
			<article class="blog-post-item">
				<div class="post-meta-data">
					<time datetime={post.date}>{formatDate(post.date)}</time>
					<span class="reading-time-badge">{post.readingTime}</span>
				</div>
				<h3 class="post-title">
					<a href={post.url} target="_blank" rel="noopener noreferrer">{post.title}</a>
				</h3>
				<p class="post-excerpt">{post.excerpt}</p>
				<a href={post.url} target="_blank" rel="noopener noreferrer" class="read-more-link">
					Read Dispatch
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<line x1="5" y1="12" x2="19" y2="12"></line>
						<polyline points="12 5 19 12 12 19"></polyline>
					</svg>
				</a>
			</article>
		))}
	</div>
	<div class="medium-footer">
		<a href="https://medium.com/@madezmedia" target="_blank" rel="noopener noreferrer" class="medium-profile-btn">
			Explore full Medium profile
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="7" y1="17" x2="17" y2="7"></line>
				<polyline points="7 7 17 7 17 17"></polyline>
			</svg>
		</a>
	</div>
</div>

<style>
	.blog-feed-container {
		margin: 2rem 0;
		padding: 0;
	}

	.blog-header {
		margin-bottom: 3rem;
	}

	.blog-section-title {
		font-family: "Playfair Display", serif;
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 900;
		color: var(--primary);
		margin: 0;
		text-transform: uppercase;
		letter-spacing: -0.02em;
	}

	.blog-section-subtitle {
		color: var(--accent-pink);
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-top: 0.5rem;
	}

	.posts-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.blog-post-item {
		padding: 2.5rem 0;
		border-bottom: 1.5px solid color-mix(in srgb, var(--primary) 15%, transparent);
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.blog-post-item:last-child {
		border-bottom: none;
	}

	.blog-post-item:hover {
		padding-left: 1rem;
		background: color-mix(in srgb, var(--primary) 3%, transparent);
	}

	.post-meta-data {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-family: "JetBrains Mono", monospace;
		font-size: 11px;
		color: color-mix(in srgb, var(--primary) 60%, transparent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 0.75rem;
	}

	.reading-time-badge {
		padding-left: 0.75rem;
		border-left: 1.5px solid color-mix(in srgb, var(--primary) 20%, transparent);
		color: var(--accent-pink);
	}

	.post-title {
		font-family: "Playfair Display", serif;
		font-size: clamp(1.4rem, 2vw, 1.85rem);
		font-weight: 800;
		line-height: 1.25;
		margin: 0 0 1rem 0;
		letter-spacing: -0.015em;
	}

	.post-title a {
		color: var(--primary);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.post-title a:hover {
		color: var(--accent-pink);
	}

	.post-excerpt {
		font-family: "Outfit", sans-serif;
		margin: 0 0 1.5rem 0;
		font-size: 1rem;
		color: color-mix(in srgb, var(--primary) 80%, transparent);
		line-height: 1.6;
		max-width: 54rem;
	}

	.read-more-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--primary);
		font-family: "JetBrains Mono", monospace;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		text-decoration: none;
		transition: gap 0.2s ease, color 0.2s ease;
	}

	.read-more-link:hover {
		gap: 0.75rem;
		color: var(--accent-pink);
	}

	.read-more-link svg {
		transition: transform 0.2s ease;
	}

	.read-more-link:hover svg {
		transform: translateX(3px);
	}

	.medium-footer {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1.5px solid var(--primary);
		display: flex;
		justify-content: flex-end;
	}

	.medium-profile-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		background: var(--primary);
		color: var(--bg-primary);
		border: 1.5px solid var(--primary);
		padding: 0.75rem 2rem;
		text-decoration: none;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.medium-profile-btn:hover {
		background: transparent;
		color: var(--primary);
		transform: translateY(-2px);
		box-shadow: 0 6px 0 var(--primary);
	}

	.medium-profile-btn svg {
		transition: transform 0.3s ease;
	}

	.medium-profile-btn:hover svg {
		transform: translate(2px, -2px);
	}
</style>