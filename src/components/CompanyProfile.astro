---
import { UX_CONFIG } from '../utils/ux';
import SocialLinks from './SocialLinks.astro';

const companyDetails = {
    name: 'Mad EZ Media',
    tagline: 'AI-Powered Digital Solutions',
    description: 'A forward-thinking digital agency specializing in voice AI, agent orchestration, SaaS platforms, and AI-driven automation for restaurants and businesses.',
    logo: '/images/mad-ez-media-logo.png',
    foundedYear: 2020,
    expertise: [
        { name: 'Voice AI Solutions', icon: '🎙️' },
        { name: 'Agent Orchestration', icon: '🤖' },
        { name: 'SaaS Platforms', icon: '💳' },
        { name: 'Restaurant Tech', icon: '🍽️' }
    ],
    achievements: [
        { metric: '6', label: 'Production Apps' },
        { metric: '$497+', label: 'MRR per Client' },
        { metric: '90%', label: 'Cost Reduction' }
    ]
};
---

<section class="company-profile-section max-w-[1440px] mx-auto px-6 md:px-[60px] py-16">
    <div class="company-container">
        <div class="company-profile-grid">
            <div class="company-logo-container">
                <img 
                    src={companyDetails.logo} 
                    alt={`${companyDetails.name} Logo`} 
                    class="company-logo"
                    loading="lazy"
                />
            </div>

            <div class="company-details">
                <div class="company-header">
                    <h2 class="company-name">{companyDetails.name}</h2>
                    <p class="company-tagline">{companyDetails.tagline}</p>
                </div>

                <div class="company-description-container">
                    <p class="company-description">
                        {companyDetails.description}
                    </p>
                </div>

                <div class="company-expertise">
                    <h3 class="section-title">Core Expertise</h3>
                    <div class="expertise-grid">
                        {companyDetails.expertise.map(skill => (
                            <div class="expertise-item">
                                <span class="expertise-icon">{skill.icon}</span>
                                <span class="expertise-name">{skill.name}</span>
                            </div>
                        ))}
                    </div>
                </div>

                <div class="company-achievements">
                    <h3 class="section-title">Company Milestones</h3>
                    <div class="achievements-grid">
                        {companyDetails.achievements.map(achievement => (
                            <div class="achievement-item">
                                <span class="achievement-metric">{achievement.metric}</span>
                                <span class="achievement-label">{achievement.label}</span>
                            </div>
                        ))}
                    </div>
                </div>

                <div class="company-socials">
                    <SocialLinks />
                </div>
            </div>
        </div>
    </div>
</section>

<style define:vars={{
    transitionDuration: `${UX_CONFIG.TRANSITION_DURATION}ms`
}}>
    .company-profile-section {
        width: 100%;
    }

    .company-container {
        background: var(--bg-secondary);
        border-radius: 0px;
        border: 2px solid var(--accent);
        padding: 3rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .company-container:hover {
        transform: translate(-6px, -6px);
        box-shadow: 6px 6px 0px var(--accent-yellow);
    }

    .company-profile-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 3rem;
        align-items: start;
    }

    .company-logo-container {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .company-logo {
        width: 100%;
        max-width: 280px;
        height: auto;
        border-radius: 0px;
        border: 4px solid var(--accent-pink);
        padding: 8px;
        background: var(--bg-primary);
    }

    .company-details {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .company-header {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .company-name {
        font-size: 3rem;
        color: var(--primary);
        margin: 0;
        font-family: "Playfair Display", serif;
        font-weight: 900;
        letter-spacing: -0.03em;
    }

    .company-tagline {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85rem;
        color: var(--accent-pink);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        margin: 0;
    }

    .company-description-container {
        background: var(--bg-primary);
        padding: 1.5rem;
        border-radius: 0px;
        border-left: 4px solid var(--accent-pink);
    }

    .company-description {
        font-family: "Montserrat", sans-serif;
        color: var(--text-primary);
        line-height: 1.7;
        margin: 0;
        font-size: 1rem;
    }

    .section-title {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.25em;
    }

    .expertise-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .expertise-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: var(--bg-primary);
        border-radius: 0px;
        border: 1px solid var(--accent);
        transition: all 0.2s ease;
    }

    .expertise-item:hover {
        transform: translate(-3px, -3px);
        box-shadow: 3px 3px 0px var(--accent-cyan);
        background: var(--bg-secondary);
    }

    .expertise-icon {
        font-size: 1.5rem;
    }

    .expertise-name {
        font-family: "Montserrat", sans-serif;
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--text-primary);
    }

    .achievements-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    .achievement-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.5rem 1rem;
        background: var(--bg-primary);
        border-radius: 0px;
        border: 1px solid var(--accent-pink);
        text-align: center;
    }

    .achievement-metric {
        font-family: "Raleway", sans-serif;
        font-size: 2.25rem;
        font-weight: 900;
        color: var(--accent-pink);
        line-height: 1;
        margin-bottom: 0.5rem;
    }

    .achievement-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.65rem;
        text-transform: uppercase;
        color: var(--text-secondary);
        letter-spacing: 0.1em;
    }

    .company-socials {
        margin-top: 0.5rem;
    }

    @media (max-width: 1024px) {
        .company-profile-grid {
            grid-template-columns: 1fr;
            gap: 2.5rem;
        }

        .company-logo-container {
            justify-content: start;
        }
    }

    @media (max-width: 768px) {
        .company-container {
            padding: 1.5rem;
        }

        .company-name {
            font-size: 2.25rem;
        }

        .expertise-grid,
        .achievements-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
