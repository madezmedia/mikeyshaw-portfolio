---
import { UX_CONFIG } from '../utils/ux';
import SocialLinks from './SocialLinks.astro';

const engagementSlots = [
    { slot: "Slot 1", status: "Engaged • Q2–Q3 2026", details: "Active development on creator media automation pipeline" },
    { slot: "Slot 2", status: "Open • Q3 2026 start", details: "Accepting inbound for custom autonomous agentic fleets", isOpen: true },
    { slot: "Slot 3", status: "Open • Q4 2026 start", details: "Accepting inbound for enterprise Voice AI systems", isOpen: true }
];

const systemStats = [
    { metric: "6+", label: "Production Apps Deployed", color: "#00B9F1" }, // Cyan
    { metric: "$497+", label: "Avg MRR per Client Client", color: "#E5007D" }, // Pink
    { metric: "90%", label: "Manual Cost Reduction", color: "#FCDC00" }  // Yellow
];
---

<section class="company-profile-section max-w-[1440px] mx-auto px-6 md:px-[60px] py-16">
    <div class="company-container">
        <div class="company-profile-grid">
            <!-- Left side: Active Engagements -->
            <div class="engagements-panel">
                <div class="home-eyebrow"><span class="num">N° 02</span>Active Engagements</div>
                <h3 class="panel-title">Studio Capacity</h3>
                <p class="panel-desc">
                    Mikey Shaw operates as a dedicated high-agency engineering studio. We limit active client slots to maintain absolute quality and focus on shipped systems.
                </p>

                <div class="slots-list">
                    {engagementSlots.map((slot) => (
                        <div class={`slot-card ${slot.isOpen ? 'slot-open' : 'slot-closed'}`}>
                            <div class="slot-header">
                                <span class="slot-num">{slot.slot}</span>
                                {slot.isOpen ? (
                                    <span class="slot-badge-open">Accepting Inbound</span>
                                ) : (
                                    <span class="slot-badge-closed">Engaged</span>
                                )}
                            </div>
                            <div class="slot-status">{slot.status}</div>
                            <p class="slot-details">{slot.details}</p>
                        </div>
                    ))}
                </div>
            </div>

            <!-- Right side: System stats -->
            <div class="stats-panel">
                <div class="home-eyebrow"><span class="num">N° 04</span>Track Record</div>
                <h3 class="panel-title">System Metrics</h3>
                
                <div class="stats-grid">
                    {systemStats.map((stat) => (
                        <div class="stat-card" style={`--stat-color: ${stat.color}`}>
                            <span class="stat-metric">{stat.metric}</span>
                            <span class="stat-label">{stat.label}</span>
                        </div>
                    ))}
                </div>

                <div class="studio-meta-box">
                    <h4 class="meta-box-title">Engine Conformance</h4>
                    <p class="meta-box-text">
                        We build custom platforms, autonomous characters, voice systems, and protocol-grade infrastructure. We do not ship slide decks. We ship <strong>working systems</strong> that run securely on Tuesday morning when nobody is watching.
                    </p>
                    <div class="socials-wrap mt-8">
                        <SocialLinks />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style define:vars={{
    transitionDuration: `${UX_CONFIG.TRANSITION_DURATION}ms`
}}>
    .company-profile-section {
        width: 100%;
    }

    .company-container {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid rgba(45, 74, 62, 0.1);
        padding: 3rem;
        box-shadow: 0 8px 24px rgba(45, 74, 62, 0.04);
    }

    .company-profile-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3.5rem;
    }

    @media (min-width: 1024px) {
        .company-profile-grid {
            grid-template-columns: 1.1fr 1fr;
        }
    }

    .home-eyebrow {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .22em;
        color: var(--accent-pink, #E5007D);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
    }

    .home-eyebrow .num {
        opacity: 0.8;
    }

    .panel-title {
        font-family: "Playfair Display", serif;
        font-size: 2.25rem;
        font-weight: 900;
        color: var(--primary, #2d4a3e);
        margin: 0 0 1rem;
        letter-spacing: -0.02em;
    }

    .panel-desc {
        font-family: "Outfit", sans-serif;
        font-size: 0.95rem;
        color: rgba(45, 74, 62, 0.75);
        line-height: 1.6;
        margin-bottom: 2rem;
    }

    .slots-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .slot-card {
        background: #faf9f5;
        border-radius: 10px;
        padding: 1.5rem;
        border-top: 4px solid rgba(45, 74, 62, 0.1);
        transition: transform 0.25s, box-shadow 0.25s;
    }

    .slot-open {
        border-top-color: var(--accent-cyan, #00B9F1);
        box-shadow: 0 4px 12px rgba(0, 185, 241, 0.04);
    }

    .slot-open:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0, 185, 241, 0.08);
    }

    .slot-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .slot-num {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        font-weight: 700;
        color: rgba(45, 74, 62, 0.5);
        text-transform: uppercase;
        letter-spacing: 0.15em;
    }

    .slot-badge-open {
        font-family: "JetBrains Mono", monospace;
        font-size: 9.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #ffffff;
        background: var(--accent-cyan, #00B9F1);
        padding: 2px 8px;
        border-radius: 9999px;
    }

    .slot-badge-closed {
        font-family: "JetBrains Mono", monospace;
        font-size: 9.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(45, 74, 62, 0.7);
        background: rgba(45, 74, 62, 0.08);
        padding: 2px 8px;
        border-radius: 9999px;
    }

    .slot-status {
        font-family: "Outfit", sans-serif;
        font-weight: 700;
        font-size: 14.5px;
        color: var(--primary, #2d4a3e);
        margin-bottom: 0.25rem;
    }

    .slot-details {
        font-family: "Outfit", sans-serif;
        font-size: 13px;
        color: rgba(45, 74, 62, 0.65);
        margin: 0;
    }

    /* Stats Panel */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1.5rem 1rem;
        background: #faf9f5;
        border-radius: 10px;
        border: 1px solid rgba(45, 74, 62, 0.08);
        text-align: center;
        border-top: 4px solid var(--stat-color);
        transition: transform 0.25s;
    }

    .stat-card:hover {
        transform: translateY(-2px);
    }

    .stat-metric {
        font-family: "Playfair Display", serif;
        font-size: 2.25rem;
        font-weight: 900;
        color: var(--primary, #2d4a3e);
        line-height: 1.1;
        margin-bottom: 0.25rem;
    }

    .stat-label {
        font-family: "Outfit", sans-serif;
        font-size: 11px;
        color: rgba(45, 74, 62, 0.6);
        line-height: 1.3;
    }

    .studio-meta-box {
        background: #faf9f5;
        padding: 1.75rem;
        border-radius: 10px;
        border-left: 4px solid var(--accent-pink, #E5007D);
        border-top: 1px solid rgba(45, 74, 62, 0.05);
        border-right: 1px solid rgba(45, 74, 62, 0.05);
        border-bottom: 1px solid rgba(45, 74, 62, 0.05);
    }

    .meta-box-title {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent-pink, #E5007D);
        margin: 0 0 0.75rem;
    }

    .meta-box-text {
        font-family: "Outfit", sans-serif;
        font-size: 13.5px;
        color: rgba(45, 74, 62, 0.8);
        line-height: 1.6;
        margin: 0;
    }
</style>
