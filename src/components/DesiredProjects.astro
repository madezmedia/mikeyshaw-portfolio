---

<section id="work" class="desired-projects-section max-w-[1440px] mx-auto px-6 md:px-[60px] py-24">
    <div class="section-header max-w-2xl mb-16">
        <div class="home-eyebrow"><span class="num">N° 03</span>Selected Deployments</div>
        <h2 class="section-title">The ACMI <em class="em-gradient">Entity Explorer</em></h2>
        <p class="section-subtitle mt-4">
            Mikey Shaw's production-grade systems modeled in their own protocol. Every project exposes its stable **Profile**, live telemetry **Signals**, and chronological **Timeline**.
        </p>
    </div>

    <div class="acmi-explorer-grid">
        {acmiEntities.map((entity) => (
            <div 
                class="acmi-card"
                style={`--card-accent: ${entity.accentColor}`}
                data-entity-id={entity.id}
            >
                <div class="acmi-card-head">
                    <div class="acmi-badge">
                        <span class="acmi-badge-tag">{entity.labelTag}</span>
                        <span class="acmi-status">{entity.status}</span>
                    </div>
                    <h3 class="acmi-title">{entity.name}</h3>
                </div>

                <div class="acmi-tabs">
                    <button class="acmi-tab-btn active" data-tab="profile">
                        <span class="tab-char" style={`background: ${entity.accentColor}`}>P</span> Profile
                    </button>
                    <button class="acmi-tab-btn" data-tab="signals">
                        <span class="tab-char" style={`background: ${entity.accentColor}`}>S</span> Signals
                    </button>
                    <button class="acmi-tab-btn" data-tab="timeline">
                        <span class="tab-char" style={`background: ${entity.accentColor}`}>T</span> Timeline
                    </button>
                </div>

                <div class="acmi-content-box">
                    <div class="acmi-path">acmi:project:{entity.id}:profile</div>
                    
                    <!-- Profile Tab (Active by default) -->
                    <div class="tab-pane active" data-pane="profile">
                        <pre class="acmi-json">{JSON.stringify(entity.profile, null, 2)}</pre>
                    </div>

                    <!-- Signals Tab -->
                    <div class="tab-pane" data-pane="signals">
                        <pre class="acmi-json">{JSON.stringify(entity.signals, null, 2)}</pre>
                    </div>

                    <!-- Timeline Tab -->
                    <div class="tab-pane" data-pane="timeline">
                        <ul class="acmi-log">
                            {entity.timeline.map((log) => (
                                <li>{log}</li>
                            ))}
                        </ul>
                    </div>
                </div>

                <div class="acmi-card-foot">
                    <span>ACMI v1.5 Protocol Conformance</span>
                </div>
            </div>
        ))}
    </div>
</section>

<script>
    // Client-side interactive tabs handler
    document.addEventListener('DOMContentLoaded', () => {
        const cards = document.querySelectorAll('.acmi-card');

        cards.forEach(card => {
            const tabButtons = card.querySelectorAll('.acmi-tab-btn');
            const tabPanes = card.querySelectorAll('.tab-pane');
            const pathDisplay = card.querySelector('.acmi-path');
            const entityId = card.getAttribute('data-entity-id');

            tabButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    const tabName = btn.getAttribute('data-tab');

                    // Set button active
                    tabButtons.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');

                    // Set pane active
                    tabPanes.forEach(pane => {
                        if (pane.getAttribute('data-pane') === tabName) {
                            pane.classList.add('active');
                        } else {
                            pane.classList.remove('active');
                        }
                    });

                    // Update displayed ACMI path
                    if (pathDisplay) {
                        pathDisplay.textContent = `acmi:project:${entityId}:${tabName}`;
                    }
                });
            });
        });
    });
</script>

<style define:vars={{
    transitionDuration: `${UX_CONFIG.TRANSITION_DURATION}ms`
}}>
    .desired-projects-section {
        width: 100%;
    }

    .home-eyebrow {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .22em;
        color: var(--accent-pink, #E5007D);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
    }

    .home-eyebrow .num {
        opacity: 0.8;
    }

    .section-title {
        font-family: "Playfair Display", serif;
        font-size: clamp(32px, 4.5vw, 56px);
        font-weight: 900;
        line-height: 1.1;
        color: var(--primary, #2d4a3e);
        margin: 0;
        letter-spacing: -0.025em;
    }

    .em-gradient {
        font-style: italic;
        background: linear-gradient(90deg, var(--accent-cyan, #00B9F1) 0, var(--accent-pink, #E5007D) 100%);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
        -webkit-text-fill-color: transparent;
    }

    .section-subtitle {
        font-family: "Outfit", sans-serif;
        font-size: 1.1rem;
        color: rgba(45, 74, 62, 0.75);
        line-height: 1.6;
    }

    .acmi-explorer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 1024px) {
        .acmi-explorer-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .acmi-card {
        background: #ffffff;
        border-radius: 14px;
        padding: 2.25rem;
        border-top: 5px solid var(--card-accent);
        box-shadow: 0 8px 24px rgba(45, 74, 62, 0.04);
        transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.32s;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        border-left: 1px solid rgba(45, 74, 62, 0.05);
        border-right: 1px solid rgba(45, 74, 62, 0.05);
        border-bottom: 1px solid rgba(45, 74, 62, 0.05);
    }

    .acmi-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 36px rgba(45, 74, 62, 0.08);
    }

    .acmi-badge {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .acmi-badge-tag {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--card-accent);
    }

    .acmi-status {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        color: rgba(45, 74, 62, 0.5);
    }

    .acmi-title {
        font-family: "Playfair Display", serif;
        font-size: 1.75rem;
        font-weight: 850;
        color: var(--primary, #2d4a3e);
        margin: 0;
        letter-spacing: -0.015em;
    }

    .acmi-tabs {
        display: flex;
        gap: 0.5rem;
        border-bottom: 1px solid rgba(45, 74, 62, 0.1);
        padding-bottom: 0.75rem;
    }

    .acmi-tab-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: "Outfit", sans-serif;
        font-size: 13.5px;
        font-weight: 600;
        color: rgba(45, 74, 62, 0.6);
        background: none;
        border: none;
        padding: 6px 12px;
        cursor: pointer;
        transition: color 0.2s;
        border-radius: 6px;
    }

    .acmi-tab-btn:hover {
        color: var(--primary, #2d4a3e);
        background: rgba(45, 74, 62, 0.03);
    }

    .acmi-tab-btn.active {
        color: var(--primary, #2d4a3e);
        background: rgba(45, 74, 62, 0.05);
    }

    .tab-char {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
        border-radius: 4px;
        color: #ffffff;
        font-family: "Playfair Display", serif;
        font-weight: 900;
        font-size: 10px;
        flex-shrink: 0;
    }

    .acmi-content-box {
        background: #faf9f5;
        border: 1px solid rgba(45, 74, 62, 0.1);
        border-radius: 8px;
        padding: 1.25rem;
        font-family: "JetBrains Mono", monospace;
        font-size: 12.5px;
        line-height: 1.65;
        color: rgba(45, 74, 62, 0.85);
        min-height: 190px;
        display: flex;
        flex-direction: column;
    }

    .acmi-path {
        font-size: 11.5px;
        color: rgba(45, 74, 62, 0.45);
        border-bottom: 1px dashed rgba(45, 74, 62, 0.1);
        padding-bottom: 0.75rem;
        margin-bottom: 0.75rem;
        word-break: break-all;
    }

    .tab-pane {
        display: none;
        flex-grow: 1;
    }

    .tab-pane.active {
        display: block;
    }

    .acmi-json {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-all;
        font-family: inherit;
        font-size: inherit;
    }

    .acmi-log {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .acmi-log li {
        position: relative;
        padding-left: 0.25rem;
    }

    .acmi-card-foot {
        font-family: "JetBrains Mono", monospace;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(45, 74, 62, 0.4);
        margin-top: auto;
    }
</style>
