<script>
    function initACMIExplorer() {
        // --- SLIDESHOW NAVIGATION ---
        const navButtons = document.querySelectorAll('.slide-nav-btn');
        const slides = document.querySelectorAll('.slideshow-slide');
        let currentSlideIndex = 0;

        const switchSlide = (slideIndex) => {
            currentSlideIndex = slideIndex;

            // Pause all videos when switching slides
            const allVideos = document.querySelectorAll('video');
            allVideos.forEach(v => {
                v.pause();
                v.classList.add('hidden');
                // show overlay again
                const overlay = v.parentElement.querySelector('.video-overlay');
                if (overlay) overlay.classList.remove('opacity-0', 'pointer-events-none');
            });

            // Update Nav buttons
            navButtons.forEach((btn, idx) => {
                if (idx === slideIndex) {
                    btn.classList.add('active');
                    btn.setAttribute('aria-selected', 'true');
                } else {
                    btn.classList.remove('active');
                    btn.setAttribute('aria-selected', 'false');
                }
            });

            // Update Slides
            slides.forEach((slide) => {
                const idx = parseInt(slide.getAttribute('data-slide-index') || '0', 10);
                if (idx === slideIndex) {
                    slide.classList.add('active');
                } else {
                    slide.classList.remove('active');
                }
            });
        };

        navButtons.forEach(btn => {
            // Remove previous event listener if any (resiliency)
            const newBtn = btn.cloneNode(true);
            btn.parentNode?.replaceChild(newBtn, btn);
            
            newBtn.addEventListener('click', () => {
                const index = parseInt(newBtn.getAttribute('data-slide') || '0', 10);
                switchSlide(index);
            });
        });

        // Re-query buttons after cloning to bind active indicators
        const activeNavButtons = document.querySelectorAll('.slide-nav-btn');

        // --- VIDEO PLAYER INTEGRATION ---
        const folanaVideo = document.getElementById('folana-mux-video') as HTMLVideoElement;
        const playBtn = document.querySelector('.play-trigger-btn');
        const videoOverlay = document.querySelector('.video-overlay');

        if (folanaVideo && playBtn && videoOverlay) {
            playBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                
                // Show video element, fade out overlay
                folanaVideo.classList.remove('hidden');
                videoOverlay.classList.add('opacity-0', 'pointer-events-none');
                
                folanaVideo.play().catch(err => console.log('Video play failed:', err));
            });

            // Let click on the video itself pause/play
            folanaVideo.addEventListener('click', () => {
                if (folanaVideo.paused) {
                    folanaVideo.play();
                } else {
                    folanaVideo.pause();
                }
            });
        }

        // --- ACMI CARD TABS HANDLER ---
        const cards = document.querySelectorAll('.acmi-card');
        cards.forEach(card => {
            const tabButtons = card.querySelectorAll('.acmi-tab-btn');
            const tabPanes = card.querySelectorAll('.tab-pane');
            const pathDisplay = card.querySelector('.acmi-path');
            const entityId = card.getAttribute('data-entity-id');

            tabButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    const tabName = btn.getAttribute('data-tab');

                    // Set button active
                    tabButtons.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');

                    // Set pane active
                    tabPanes.forEach(pane => {
                        if (pane.getAttribute('data-pane') === tabName) {
                            pane.classList.add('active');
                        } else {
                            pane.classList.remove('active');
                        }
                    });

                    // Update displayed ACMI path
                    if (pathDisplay) {
                        pathDisplay.textContent = `acmi:project:${entityId}:${tabName}`;
                    }
                });
            });
        });

        // --- LIVE ACMI DATA RAG HYDRATION ---
        fetch('/api/acmi-data')
            .then(res => res.json())
            .then(data => {
                if (data.error) return;
                
                Object.keys(data).forEach(id => {
                    const card = document.querySelector(`.acmi-card[data-entity-id="${id}"]`);
                    if (!card) return;

                    const record = data[id];
                    
                    // Update status label if we have live signals status
                    const statusEl = card.querySelector('.acmi-status');
                    if (statusEl && record.signals && record.signals.status) {
                        const capitalized = record.signals.status.charAt(0).toUpperCase() + record.signals.status.slice(1);
                        const subInfo = id === 'folana-cns' ? 'EP251 Active' : 
                                        id === 'ez-influencer' ? 'Live • Whop Certified' : 
                                        id === 'mad-ez-v2' ? 'Deployed • <10ms Cache' : 'Live • Gold Theme';
                        statusEl.textContent = `${capitalized} • ${subInfo}`;
                    }

                    // Update Profile Pane JSON
                    const profileJsonEl = card.querySelector('[data-pane="profile"] .acmi-json');
                    if (profileJsonEl && record.profile) {
                        profileJsonEl.textContent = JSON.stringify(record.profile, null, 2);
                    }

                    // Update Signals Pane JSON
                    const signalsJsonEl = card.querySelector('[data-pane="signals"] .acmi-json');
                    if (signalsJsonEl && record.signals) {
                        signalsJsonEl.textContent = JSON.stringify(record.signals, null, 2);
                    }

                    // Update Timeline Pane List
                    const timelineLogEl = card.querySelector('[data-pane="timeline"] .acmi-log');
                    if (timelineLogEl && record.timeline && record.timeline.length) {
                        timelineLogEl.innerHTML = '';
                        record.timeline.forEach(evt => {
                            const li = document.createElement('li');
                            li.textContent = evt.startsWith('→') ? evt : `→ ${evt}`;
                            timelineLogEl.appendChild(li);
                        });
                    }

                    // Pulse effect
                    card.classList.add('hydrated');
                    setTimeout(() => card.classList.remove('hydrated'), 1200);
                });
            })
            .catch(err => console.warn('Could not fetch live ACMI explorer data:', err));
    }

    // Initialize
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initACMIExplorer);
    } else {
        initACMIExplorer();
    }

    // Support Astro View Transitions
    document.addEventListener('astro:page-load', initACMIExplorer);
</script>

