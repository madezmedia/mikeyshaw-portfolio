---

<section id="work" class="desired-projects-section max-w-[1440px] mx-auto px-6 md:px-[60px] py-24">
    <div class="section-header max-w-2xl mb-16">
        <div class="home-eyebrow"><span class="num">N° 03</span>Selected Deployments</div>
        <h2 class="section-title">The ACMI <em class="em-gradient">Entity Explorer</em></h2>
        <p class="section-subtitle mt-4">
            Mikey Shaw's production-grade systems modeled in their own protocol. Every project exposes its stable **Profile**, live telemetry **Signals**, and chronological **Timeline**.
        </p>
    </div>

    <!-- Slideshow Tabs Selector -->
    <div class="slideshow-nav-container mb-12">
        <div class="slideshow-nav" role="tablist">
            {acmiEntities.map((entity, index) => (
                <button 
                    class={`slide-nav-btn ${index === 0 ? 'active' : ''}`} 
                    data-slide={index} 
                    role="tab" 
                    aria-selected={index === 0 ? 'true' : 'false'} 
                    aria-controls={`slide-${entity.id}`}
                >
                    <span class="slide-num">0{index + 1}</span>
                    <span class="slide-label">{entity.name}</span>
                    <span class="active-indicator" style={`background: ${entity.accentColor};`}></span>
                </button>
            ))}
        </div>
    </div>

    <!-- Slideshow Wrapper -->
    <div class="slideshow-container relative min-h-[650px] md:min-h-[600px]">
        
        <!-- Slide 0: Folana -->
        <div id="slide-folana-cns" class="slideshow-slide active" data-slide-index="0" role="tabpanel">
            <div class="slide-grid">
                <!-- Specs Panel -->
                <div class="acmi-card" style="--card-accent: #1e4d36;" data-entity-id="folana-cns">
                    <div class="acmi-card-head">
                        <div class="acmi-badge">
                            <span class="acmi-badge-tag">Autonomous Influencer CNS</span>
                            <span class="acmi-status">EP251 Active • 70 BPM Drop</span>
                        </div>
                        <h3 class="acmi-title">Folana Lanez</h3>
                        <p class="project-brief mt-3 text-sm text-gray-600 leading-relaxed font-sans">
                            An end-to-end autonomous character recovery and content generation system. Mikey built a sync bridge to query production Upstash Redis, extract locked safetensors LoRA weights from Whop integrations, and run RunPod InfiniteTalk lip-sync generations. Featured here is her latest production episode: <strong>EP251 — The Forest Speaks</strong>.
                        </p>
                    </div>

                    <div class="acmi-tabs">
                        <button class="acmi-tab-btn active" data-tab="profile">
                            <span class="tab-char" style="background: #1e4d36;">P</span> Profile
                        </button>
                        <button class="acmi-tab-btn" data-tab="signals">
                            <span class="tab-char" style="background: #1e4d36;">S</span> Signals
                        </button>
                        <button class="acmi-tab-btn" data-tab="timeline">
                            <span class="tab-char" style="background: #1e4d36;">T</span> Timeline
                        </button>
                    </div>

                    <div class="acmi-content-box">
                        <div class="acmi-path">acmi:project:folana-cns:profile</div>
                        
                        <!-- Profile Tab (Active by default) -->
                        <div class="tab-pane active" data-pane="profile">
                            <pre class="acmi-json">{JSON.stringify(acmiEntities[0].profile, null, 2)}</pre>
                        </div>

                        <!-- Signals Tab -->
                        <div class="tab-pane" data-pane="signals">
                            <pre class="acmi-json">{JSON.stringify(acmiEntities[0].signals, null, 2)}</pre>
                        </div>

                        <!-- Timeline Tab -->
                        <div class="tab-pane" data-pane="timeline">
                            <ul class="acmi-log">
                                {acmiEntities[0].timeline.map((log) => (
                                    <li>{log}</li>
                                ))}
                            </ul>
                        </div>
                    </div>

                    <div class="acmi-card-foot flex justify-between items-center text-[10px] font-mono text-gray-400">
                        <span>ACMI v1.5 Protocol Conformance</span>
                        <a href="https://folana.live/folana/premium/ep251" target="_blank" class="hover:text-[#e8a930] transition-colors underline">View Premium Page</a>
                    </div>
                </div>

                <!-- Media Showcase Panel (Folana Video) -->
                <div class="media-showcase-panel flex flex-col justify-center">
                    <div class="video-player-container relative rounded-2xl overflow-hidden shadow-2xl border border-white/5 aspect-video bg-[#0a1f12]">
                        <video 
                            id="folana-mux-video" 
                            class="w-full h-full object-cover hidden" 
                            controls 
                            playsinline
                            src="https://folana.live/folana/premium/ep251/ep251-music-video.mp4"
                        ></video>
                        
                        <div class="video-overlay absolute inset-0 flex flex-col justify-between p-8 bg-gradient-to-t from-black/85 via-black/35 to-black/60 transition-all duration-300">
                            <!-- Top Info -->
                            <div class="flex justify-between items-start">
                                <div class="glass-pill text-[10px] font-mono text-[#e8a930] tracking-wider uppercase border border-[#e8a930]/20 px-3 py-1 bg-[#0a1f12]/60 backdrop-blur-md flex items-center gap-2">
                                    <span class="w-1.5 h-1.5 rounded-full bg-[#e8a930] animate-ping"></span>
                                    Episode 251 Release
                                </div>
                                <div class="glass-pill text-[10px] font-mono text-white/75 tracking-wider uppercase border border-white/10 px-3 py-1 bg-white/5 backdrop-blur-md">
                                    70 BPM • D Major
                                </div>
                            </div>

                            <!-- Image & Play Trigger -->
                            <div class="video-cover-img-wrap absolute inset-0 -z-10 w-full h-full">
                                <img 
                                    src="https://folana.live/folana/premium/ep251/ep251-hero.jpg" 
                                    alt="Folana Episode 251 Canopy Hero" 
                                    class="w-full h-full object-cover" 
                                />
                            </div>

                            <!-- Play Button Area -->
                            <button class="play-trigger-btn group mx-auto my-auto w-20 h-20 rounded-full bg-black/50 hover:bg-black/70 backdrop-blur-md border border-white/20 flex items-center justify-center transition-all duration-300 hover:scale-115 focus:outline-none focus:ring-2 focus:ring-[#e8a930] shadow-[0_0_50px_rgba(232,169,48,0.4)]">
                                <svg class="w-8 h-8 text-white fill-current translate-x-0.5 group-hover:scale-110 transition-transform" viewBox="0 0 24 24">
                                    <path d="M8 5v14l11-7z"/>
                                </svg>
                            </button>

                            <!-- Bottom Info -->
                            <div class="space-y-2 text-white/90">
                                <h4 class="font-bold text-lg leading-tight tracking-tight">"The forest speaks in a language older than sound."</h4>
                                <p class="text-xs text-white/60 font-mono flex items-center gap-2">
                                    <span class="w-1.5 h-1.5 rounded-full bg-[#e8a930]"></span>
                                    MiniMax-M2.6 Audio + RunPod InfiniteTalk (Landscape Video)
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

