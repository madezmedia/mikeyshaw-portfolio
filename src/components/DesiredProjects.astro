---
import { UX_CONFIG } from '../utils/ux';

interface DesiredProject {
    icon: string;
    title: string;
    description: string;
    tags: string[];
    color: string;
}

const desiredProjects: DesiredProject[] = [
    {
        icon: '🤖',
        title: 'Multi-Agent Orchestration',
        description: '3+ frameworks tested with production systems deployed. LangChain, AutoGPT, SuperAGI, and YAO expertise.',
        tags: ['LangChain', 'AutoGPT', 'SuperAGI'],
        color: '#E5007D' // Madez Pink
    },
    {
        icon: '🎙️',
        title: 'Voice AI Architecture',
        description: 'VAPI + OpenClaw pattern for building conversational AI agents that answer phones and capture leads.',
        tags: ['VAPI', 'ElevenLabs', 'OpenAI Realtime'],
        color: '#00B9F1' // Madez Blue
    },
    {
        icon: '🍽️',
        title: 'Restaurant Technology',
        description: 'Domain expertise from 3+ products in the restaurant space — phone automation, lead gen, social media.',
        tags: ['OpenClaw', 'OwnerScout', 'YAO'],
        color: '#FCDC00' // Madez Yellow
    },
    {
        icon: '💳',
        title: 'SaaS Platform Development',
        description: 'Full-stack products with Stripe payments, Supabase auth, multi-tenant architecture, and user workflows.',
        tags: ['Stripe', 'Supabase', 'Next.js'],
        color: '#00B9F1' // Madez Blue
    },
    {
        icon: '⚡',
        title: 'Performance Optimization',
        description: '80-95% API cost reduction through multi-tier caching, rate limiting, and recursive splitting patterns.',
        tags: ['Caching', 'Rate Limiting', '9x Speed'],
        color: '#E5007D' // Madez Pink
    },
    {
        icon: '🎵',
        title: 'AI Audio & Media',
        description: 'Voice synthesis, music generation, video AI with production pipelines from concept to published content.',
        tags: ['ElevenLabs', 'RunPod', 'Mux'],
        color: '#9C198C' // Madez Purple
    }
];
---

<section id="desired-projects" class="desired-projects-section max-w-[1440px] mx-auto px-6 md:px-[60px] py-16">
    <div class="section-header">
        <h2 class="section-title">Expertise & Specializations</h2>
        <p class="section-subtitle">Production-Tested Skills Across AI, Voice, and SaaS</p>
    </div>

    <div class="projects-grid">
        {desiredProjects.map((project) => (
            <div 
                class="project-card"
                style={`--project-color: ${project.color}`}
            >
                <div class="icon-container">
                    <span class="project-icon">{project.icon}</span>
                </div>
                
                <h3 class="project-title">{project.title}</h3>
                <p class="project-description">{project.description}</p>

                <div class="project-tags">
                    {project.tags.map(tag => (
                        <span class="tag">{tag}</span>
                    ))}
                </div>
            </div>
        ))}
    </div>
</section>

<style define:vars={{
    transitionDuration: `${UX_CONFIG.TRANSITION_DURATION}ms`
}}>
    .desired-projects-section {
        width: 100%;
    }

    .section-header {
        text-align: left;
        margin-bottom: 4rem;
        border-bottom: 2px solid var(--primary);
        opacity: 0.8;
        padding-bottom: 2rem;
    }

    .section-title {
        font-family: "Playfair Display", serif;
        font-size: 3rem;
        font-weight: 900;
        color: var(--primary);
        margin: 0;
        letter-spacing: -0.03em;
        text-transform: uppercase;
    }

    .section-subtitle {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85rem;
        color: var(--accent-pink);
        margin-top: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
    }

    .project-card {
        background: var(--bg-secondary);
        border-radius: 0px;
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        align-items: start;
        text-align: left;
        transition: 
            transform 0.2s ease,
            box-shadow 0.2s ease;
        position: relative;
        overflow: hidden;
        border: 2px solid var(--project-color);
    }

    .project-card:hover {
        transform: translate(-6px, -6px);
        box-shadow: 6px 6px 0px var(--project-color);
    }

    .icon-container {
        width: 60px;
        height: 60px;
        background: var(--bg-primary);
        border-radius: 0px;
        border: 2px solid var(--project-color);
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 2rem;
        transition: transform 0.2s ease;
    }

    .project-card:hover .icon-container {
        transform: scale(1.1) rotate(5deg);
    }

    .project-icon {
        font-size: 2rem;
    }

    .project-title {
        font-family: "Playfair Display", serif;
        font-size: 1.5rem;
        font-weight: 850;
        color: var(--primary);
        margin: 0 0 1.25rem;
        border-left: 4px solid var(--project-color);
        padding-left: 0.75rem;
    }

    .project-description {
        font-family: "Outfit", sans-serif;
        color: var(--text-primary);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 2rem;
        flex-grow: 1;
    }

    .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tag {
        background: var(--bg-secondary);
        color: var(--primary);
        padding: 0.25rem 0.75rem;
        border-radius: 0px;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.75rem;
        font-weight: 600;
        border: 1px solid var(--project-color);
    }

    @media (max-width: 768px) {
        .projects-grid {
            grid-template-columns: 1fr;
        }

        .section-title {
            font-size: 2.25rem;
        }
    }
</style>
