---
import { UX_CONFIG } from '../utils/ux';

const githubUsername = 'madezmedia';
const githubStatsImages = [
    {
        src: `https://github-profile-summary-cards.vercel.app/api/cards/profile-details?username=${githubUsername}&theme=dark`,
        alt: 'GitHub Profile Details',
        title: 'GitHub Profile Overview'
    },
    {
        src: `https://github-profile-summary-cards.vercel.app/api/cards/repos-per-language?username=${githubUsername}&theme=dark`,
        alt: 'Top Languages',
        title: 'Repositories per Language'
    },
    {
        src: `https://github-readme-streak-stats.herokuapp.com/?user=${githubUsername}&theme=dark&hide_border=true&background=1a1a1a&ring=00BCD4&fire=FFCC00&currStreakLabel=FFFFFF&sideNums=CC6688&sideLabels=FFFFFF&dates=00BCD4`,
        alt: 'GitHub Streak Stats',
        title: 'Contribution Streak'
    }
];
---

<div class="github-stats-container w-full flex flex-col gap-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {githubStatsImages.map((image) => (
            <div class="github-stat-image-container">
                <img 
                    data-src={image.src} 
                    alt={image.alt} 
                    title={image.title}
                    loading="lazy"
                    decoding="async"
                    width="480"
                    height="240"
                    class="github-stat-image"
                />
            </div>
        ))}
    </div>

    <div class="flex justify-start">
        <a 
            href={`https://github.com/${githubUsername}`} 
            target="_blank" 
            rel="noopener noreferrer"
            class="profile-link"
        >
            Explore Full GitHub Profile
        </a>
    </div>
</div>

<style define:vars={{
    transitionDuration: `${UX_CONFIG.TRANSITION_DURATION}ms`
}}>
    .github-stats-container {
        width: 100%;
    }

    .github-stat-image-container {
        background: var(--bg-secondary);
        border-radius: 0px;
        border: 2px solid var(--accent);
        overflow: hidden;
        transition: 
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .github-stat-image-container:hover {
        transform: translate(-4px, -4px);
        box-shadow: 4px 4px 0px var(--accent-pink);
    }

    .github-stat-image {
        width: 100%;
        height: auto;
        display: block;
        object-fit: cover;
        border-radius: 0px;
        filter: saturate(0.85) contrast(1.1);
        transition: filter 0.2s ease;
    }

    .github-stat-image:hover {
        filter: saturate(1.1) contrast(1.2);
    }

    .profile-link {
        font-family: "Montserrat", sans-serif;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        background: var(--accent-yellow);
        color: #000000;
        padding: 1rem 2rem;
        text-decoration: none;
        border-radius: 0px;
        border: 2px solid var(--accent-yellow);
        transition: all 0.2s ease;
        display: inline-block;
    }

    .profile-link:hover {
        background: transparent;
        color: var(--accent-yellow);
        transform: translate(-4px, -4px);
        box-shadow: 4px 4px 0px var(--accent-cyan);
    }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll('.github-stat-image');
    
    const imageObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const img = entry.target;
                if (img instanceof HTMLImageElement) {
                    img.src = img.dataset.src || '';
                    observer.unobserve(img);
                }
            }
        });
    }, { rootMargin: '100px' });

    images.forEach(img => imageObserver.observe(img));
});
</script>
