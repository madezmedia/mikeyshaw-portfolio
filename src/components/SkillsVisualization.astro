    .meta-value {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.9rem;
        font-weight: 600;
        color: #2d4a3e;
    }

    .meta-value-link {
        font-family: "Outfit", sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: #2d4a3e;
        border-bottom: 1px solid rgba(45, 74, 62, 0.2);
        display: inline-block;
        width: fit-content;
        cursor: default;
    }
</style>
