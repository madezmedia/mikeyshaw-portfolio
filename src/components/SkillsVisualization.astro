---
import { UX_CONFIG } from '../utils/ux';

// Data mapping to the client-side D3 network
const skillsData = {
    nodes: [        
        // Groups: 1=Voice AI (Cyan), 2=Agent Frameworks (Pink), 3=Web/SaaS (Yellow), 4=Core (White)
        { id: "AI Architect", group: 4, value: 20, icon: "👑" },
        
        // Voice AI
        { id: "Voice AI", group: 1, value: 15, icon: "🎙️" },
        { id: "VAPI", group: 1, value: 11 },
        { id: "ElevenLabs", group: 1, value: 10 },
        { id: "OpenAI Realtime", group: 1, value: 10 },
        { id: "OpenAI", group: 1, value: 12 },
        
        // Agent Orchestration
        { id: "Agent Frameworks", group: 2, value: 15, icon: "🤖" },
        { id: "LangChain", group: 2, value: 10 },
        { id: "AutoGPT", group: 2, value: 9 },
        { id: "YAO", group: 2, value: 9 },
        { id: "SuperAGI", group: 2, value: 8 },
        
        // Web/SaaS
        { id: "Web & SaaS", group: 3, value: 15, icon: "💻" },
        { id: "Next.js", group: 3, value: 12 },
        { id: "React", group: 3, value: 11 },
        { id: "TypeScript", group: 3, value: 11 },
        { id: "Supabase", group: 3, value: 11 },
        { id: "Stripe", group: 3, value: 9 },
        { id: "Prisma", group: 3, value: 9 },
        { id: "Node.js", group: 3, value: 10 }
    ],
    links: [
        { source: "AI Architect", target: "Voice AI", value: 5 },
        { source: "AI Architect", target: "Agent Frameworks", value: 5 },
        { source: "AI Architect", target: "Web & SaaS", value: 5 },
        
        { source: "Voice AI", target: "VAPI", value: 3 },
        { source: "Voice AI", target: "ElevenLabs", value: 3 },
        { source: "Voice AI", target: "OpenAI Realtime", value: 3 },
        { source: "Voice AI", target: "OpenAI", value: 4 },
        { source: "VAPI", target: "OpenAI", value: 2 },
        
        { source: "Agent Frameworks", target: "LangChain", value: 3 },
        { source: "Agent Frameworks", target: "AutoGPT", value: 3 },
        { source: "Agent Frameworks", target: "YAO", value: 3 },
        { source: "Agent Frameworks", target: "SuperAGI", value: 3 },
        { source: "LangChain", target: "OpenAI", value: 2 },
        
        { source: "Web & SaaS", target: "Next.js", value: 3 },
        { source: "Web & SaaS", target: "React", value: 3 },
        { source: "Web & SaaS", target: "TypeScript", value: 3 },
        { source: "Web & SaaS", target: "Supabase", value: 3 },
        { source: "Web & SaaS", target: "Stripe", value: 3 },
        { source: "Web & SaaS", target: "Prisma", value: 3 },
        { source: "Web & SaaS", target: "Node.js", value: 3 },
        { source: "React", target: "TypeScript", value: 2 },
        { source: "Next.js", target: "React", value: 2 },
        { source: "Node.js", target: "TypeScript", value: 2 },
        { source: "Supabase", target: "Prisma", value: 2 }
    ]
};
---

<div class="skills-visualization-container w-full">
    <div class="canvas-container">
        <canvas id="skills-canvas" data-skills={JSON.stringify(skillsData)}></canvas>
        <span class="overlay-instruction">Drag nodes to explore • Scroll to zoom</span>
        <div id="tooltip" class="skill-tooltip"></div>
    </div>
</div>

<script>
    import * as d3 from 'd3';

    interface SkillNode extends d3.SimulationNodeDatum {
        id: string;
        group: number;
        value: number;
        icon?: string;
        x?: number;
        y?: number;
        fx?: number | null;
        fy?: number | null;
    }

    interface SkillLink extends d3.SimulationLinkDatum<SkillNode> {
        source: string | SkillNode;
        target: string | SkillNode;
        value: number;
    }

    const canvas = document.getElementById('skills-canvas') as HTMLCanvasElement;
    if (canvas) {
        const container = canvas.parentElement;
        const tooltip = document.getElementById('tooltip');
        
        if (container) {
            const rawData = JSON.parse(canvas.dataset.skills || '{}');
            const rawNodes: any[] = rawData.nodes || [];
            const rawLinks: any[] = rawData.links || [];

            const isMobile = window.innerWidth <= 768;
            let width = container.clientWidth;
            let height = isMobile ? 350 : 600;
            
            const scale = window.devicePixelRatio || 1;
            canvas.width = width * scale;
            canvas.height = height * scale;
            canvas.style.width = `${width}px`;
            canvas.style.height = `${height}px`;
            
            const context = canvas.getContext('2d');
            if (context) context.scale(scale, scale);

            // Group colors mapping exactly to brand palette:
            // 1=Voice AI (Cyan/Blue), 2=Agent Frameworks (Pink), 3=Web/SaaS (Yellow), 4=Core (Purple)
            const colorScale = d3.scaleOrdinal<string>()
                .domain(['1', '2', '3', '4'])
                .range(['#00B9F1', '#E5007D', '#FCDC00', '#9C198C']);

            const nodes: SkillNode[] = rawNodes.map(d => ({...d}));
            const links: SkillLink[] = rawLinks.map(d => ({...d}));

            const linkDist = isMobile ? 60 : 100;
            const chargeStr = isMobile ? -150 : -355;
            const nodeScale = isMobile ? 1.0 : 1.4;
            const fontSize = isMobile ? 10 : 12;
            const iconSize = isMobile ? 12 : 16;

            const simulation = d3.forceSimulation<SkillNode>(nodes)
                .force("link", d3.forceLink<SkillNode, SkillLink>(links).id((d) => d.id).distance(linkDist))
                .force("charge", d3.forceManyBody().strength(chargeStr))
                .force("center", d3.forceCenter(width / 2, height / 2))
                .force("collide", d3.forceCollide<SkillNode>().radius((d) => d.value * nodeScale + 8));

            // Drag behavior
            const drag = (sim: d3.Simulation<SkillNode, undefined>) => {
                function dragstarted(event: any) {
                    if (!event.active) sim.alphaTarget(0.3).restart();
                    event.subject.fx = event.subject.x;
                    event.subject.fy = event.subject.y;
                    canvas.style.cursor = 'grabbing';
                }
                
                function dragged(event: any) {
                    event.subject.fx = event.x;
                    event.subject.fy = event.y;
                }
                
                function dragended(event: any) {
                    if (!event.active) sim.alphaTarget(0);
                    event.subject.fx = null;
                    event.subject.fy = null;
                    canvas.style.cursor = 'grab';
                }
                
                return d3.drag<HTMLCanvasElement, SkillNode>()
                    .subject((event) => {
                        const [x, y] = [event.x, event.y];
                        let subject = null;
                        let distance = Infinity;
                        for (const node of nodes) {
                            const dist = Math.sqrt((x - node.x!) ** 2 + (y - node.y!) ** 2);
                            if (dist < distance && dist < 35) {
                                distance = dist;
                                subject = node;
                            }
                        }
                        return subject as any;
                    })
                    .on("start", dragstarted)
                    .on("drag", dragged)
                    .on("end", dragended);
            };

            d3.select(canvas).call(drag(simulation as any) as any);

            let hoverNode: SkillNode | null = null;

            d3.select(canvas).on("mousemove", (event) => {
                const [mouseX, mouseY] = d3.pointer(event);
                
                let prevHover = hoverNode;
                hoverNode = null;
                
                for (const node of nodes) {
                    const dist = Math.sqrt((mouseX - node.x!) ** 2 + (mouseY - node.y!) ** 2);
                    if (dist < node.value * nodeScale + 8) {
                        hoverNode = node;
                        break;
                    }
                }

                if (hoverNode !== prevHover) {
                    canvas.style.cursor = hoverNode ? 'pointer' : 'default';
                    
                    if (hoverNode && tooltip) {
                        tooltip.style.opacity = '1';
                        tooltip.innerHTML = `<strong>${hoverNode.id}</strong>`;
                        tooltip.style.left = `${event.pageX + 12}px`;
                        tooltip.style.top = `${event.pageY - 12}px`;
                    } else if (tooltip) {
                        tooltip.style.opacity = '0';
                    }
                }
                
                if (hoverNode) restart();
            });

            function restart() {
                if (!context) return;
                context.clearRect(0, 0, width, height);
                
                // Draw links
                context.save();
                context.globalAlpha = 0.12;
                context.strokeStyle = "#2d4a3e";
                context.beginPath();
                links.forEach((link) => {
                    const s = link.source as SkillNode;
                    const t = link.target as SkillNode;
                    context.moveTo(s.x!, s.y!);
                    context.lineTo(t.x!, t.y!);
                });
                context.stroke();
                context.restore();

                // Highlight connected links
                if (hoverNode) {
                    context.save();
                    context.strokeStyle = "#00B9F1";
                    context.globalAlpha = 0.6;
                    context.lineWidth = 2;
                    context.beginPath();
                    links.forEach((link) => {
                        const s = link.source as SkillNode;
                        const t = link.target as SkillNode;
                        if (s.id === hoverNode!.id || t.id === hoverNode!.id) {
                            context.moveTo(s.x!, s.y!);
                            context.lineTo(t.x!, t.y!);
                        }
                    });
                    context.stroke();
                    context.restore();
                }

                // Draw nodes
                nodes.forEach((node) => {
                    context.beginPath();
                    const radius = node.value * nodeScale;
                    const isHovered = hoverNode === node;
                    const isConnected = hoverNode && links.some((l) => {
                        const s = l.source as SkillNode;
                        const t = l.target as SkillNode;
                        return (s.id === hoverNode!.id && t.id === node.id) ||
                               (t.id === hoverNode!.id && s.id === node.id);
                    });

                    const pulse = Math.sin(Date.now() / 800 + node.index!) * 1.2;
                    
                    context.arc(node.x!, node.y!, isHovered ? radius + 4 : radius + pulse, 0, 2 * Math.PI);
                    context.fillStyle = colorScale(String(node.group));
                    
                    context.save();
                    if (isHovered) {
                        context.shadowBlur = 15;
                        context.shadowColor = colorScale(String(node.group));
                    } else if (isConnected) {
                        context.shadowBlur = 8;
                        context.shadowColor = colorScale(String(node.group));
                    } else {
                        context.shadowBlur = 0;
                    }
                    
                    context.fill();
                    context.restore();
                    context.strokeStyle = "#faf9f5";
                    context.lineWidth = 2;
                    context.stroke();

                    // Node titles - legibly forest green
                    context.fillStyle = "#2d4a3e";
                    context.font = `${isHovered ? '900 ' : '600 '}${fontSize}px 'JetBrains Mono', monospace`;
                    context.textAlign = "center";
                    context.textBaseline = "middle";
                    
                    if (node.value > 12 || isHovered || isConnected) {
                        context.fillText(node.id, node.x!, node.y! + radius + 15);
                    }
                    
                    if (node.icon) {
                         context.font = `${iconSize}px Arial`;
                         context.fillText(node.icon, node.x!, node.y!);
                    }
                });
            }

            d3.timer(restart);

            // Resizing handler
            window.addEventListener('resize', () => {
                const newMobile = window.innerWidth <= 768;
                width = container.clientWidth;
                height = newMobile ? 350 : 600;
                
                const s = window.devicePixelRatio || 1;
                canvas.width = width * s;
                canvas.height = height * s;
                canvas.style.width = `${width}px`;
                canvas.style.height = `${height}px`;
                
                const ctx = canvas.getContext('2d');
                if (ctx) ctx.scale(s, s);
                
                simulation.force("center", d3.forceCenter(width / 2, height / 2));
                simulation.alpha(0.3).restart();
            });
        }
    }
</script>

<style define:vars={{
     transitionDuration: `${UX_CONFIG.TRANSITION_DURATION}ms`
}}>
    .skills-visualization-container {
        width: 100%;
    }

    .canvas-container {
        position: relative;
        width: 100%;
        background: radial-gradient(circle at center, #faf9f5 0%, #f5f4ed 100%);
        border-radius: 0px;
        border: 2px solid var(--primary);
        overflow: hidden;
        cursor: grab;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .canvas-container:active {
        cursor: grabbing;
    }

    .canvas-container:hover {
        transform: translate(-6px, -6px);
        box-shadow: 6px 6px 0px var(--accent-pink);
    }

    #skills-canvas {
        display: block;
        width: 100%;
    }

    .overlay-instruction {
        position: absolute;
        bottom: 0.75rem;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(45, 74, 62, 0.4);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem;
        pointer-events: none;
        letter-spacing: 0.05em;
    }

    .skill-tooltip {
        position: absolute;
        pointer-events: none;
        background: #faf9f5;
        color: #2d4a3e;
        padding: 6px 12px;
        border-radius: 0px;
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        opacity: 0;
        transition: opacity 0.15s;
        z-index: 10;
        border: 2px solid var(--primary);
    }

    @media (max-width: 768px) {
        .canvas-container {
            border-radius: 0px;
        }

        .overlay-instruction {
            font-size: 0.6rem;
            width: 90%;
            text-align: center;
        }
    }
</style>
