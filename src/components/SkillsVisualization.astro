---

<section id="stack" class="skills-section-wrapper max-w-[1440px] mx-auto px-6 md:px-[60px] py-24">
    <div class="section-header max-w-2xl mb-16">
        <div class="home-eyebrow"><span class="num">N° 02</span>Technical Network</div>
        <h2 class="section-title">The Synaptic <em class="em-gradient">Integration Bus</em></h2>
        <p class="section-subtitle mt-4">
            An interactive representation of Mikey's tech stack. Drag nodes to inspect physical relations; hover or click to query file paths, metrics, and live deployment details.
        </p>
    </div>

    <div class="skills-interactive-grid">
        <!-- Interactive D3 Network -->
        <div class="canvas-panel">
            <canvas id="skills-canvas" data-skills={JSON.stringify(skillsData)}></canvas>
            <span class="overlay-instruction">Drag nodes to disrupt gravity • Hover to query</span>
        </div>
        
        <!-- Live Intel Inspector Panel -->
        <div class="details-panel">
            <!-- Default Overview Panel -->
            <div id="skill-default-view" class="skill-detail-view active">
                <div class="intel-header">
                    <span class="intel-badge">SYSTEM OVERVIEW</span>
                    <h3 class="intel-title">Connected Swarm Stack</h3>
                </div>
                <div class="intel-body">
                    <p class="intel-desc">
                        Select, hover, or drag any node on the synaptic canvas to activate the telemetry scanner. This panel will pull direct data from local codebases, Supabase schemas, and Redis caches.
                    </p>
                    <div class="overview-stats">
                        <div class="stat-row">
                            <span class="stat-label">Active Swarm Nodes</span>
                            <span class="stat-value">12 Core Platforms</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Event Bus Standard</span>
                            <span class="stat-value">ACMI v1.5 Protocol</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">System Performance</span>
                            <span class="stat-value">&lt;10ms DB Latency</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Active Inspector Panel -->
            <div id="skill-active-view" class="skill-detail-view">
                <div class="intel-header">
                    <span class="intel-badge" id="active-category">Voice AI</span>
                    <h3 class="intel-title" id="active-title">VAPI Integration</h3>
                </div>
                <div class="intel-body">
                    <div class="intel-meta-item">
                        <span class="meta-label">Project Correlation</span>
                        <div class="meta-value-link" id="active-project">folanas-journal</div>
                    </div>
                    <div class="intel-meta-item">
                        <span class="meta-label">Deployment Metrics</span>
                        <div class="meta-value" id="active-metrics">Sub-100ms voice pipeline</div>
                    </div>
                    <div class="intel-meta-item">
                        <span class="meta-label">Technical Scope & Implementation</span>
                        <p class="intel-desc" id="active-desc">
                            Engineered conversational vocal synthesis nodes.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import * as d3 from 'd3';

    interface SkillNode extends d3.SimulationNodeDatum {
        id: string;
        group: number;
        value: number;
        icon?: string;
        category?: string;
        project?: string;
        metrics?: string;
        desc?: string;
        x?: number;
        y?: number;
        fx?: number | null;
        fy?: number | null;
    }

    interface SkillLink extends d3.SimulationLinkDatum<SkillNode> {
        source: string | SkillNode;
        target: string | SkillNode;
        value: number;
    }

    const canvas = document.getElementById('skills-canvas') as HTMLCanvasElement;
    if (canvas) {
        const container = canvas.parentElement;
        
        if (container) {
            const rawData = JSON.parse(canvas.dataset.skills || '{}');
            const rawNodes: any[] = rawData.nodes || [];
            const rawLinks: any[] = rawData.links || [];

            const isMobile = window.innerWidth <= 768;
            let width = container.clientWidth || Math.min(window.innerWidth - 48, 800);
            let height = isMobile ? 380 : 500;
            
            const scale = window.devicePixelRatio || 1;
            canvas.width = width * scale;
            canvas.height = height * scale;
            canvas.style.width = `${width}px`;
            canvas.style.height = `${height}px`;
            
            const context = canvas.getContext('2d');
            if (context) context.scale(scale, scale);

            // Dynamic colors corresponding to group category
            const colorScale = d3.scaleOrdinal<string>()
                .domain(['1', '2', '3', '4'])
                .range(['#00B9F1', '#E5007D', '#FCDC00', '#2d4a3e']);

            const nodes: SkillNode[] = rawNodes.map(d => ({...d}));
            const links: SkillLink[] = rawLinks.map(d => ({...d}));

            const linkDist = isMobile ? 55 : 85;
            const chargeStr = isMobile ? -140 : -280;
            const nodeScale = isMobile ? 0.95 : 1.25;
            const fontSize = isMobile ? 10 : 11;

            const simulation = d3.forceSimulation<SkillNode>(nodes)
                .force("link", d3.forceLink<SkillNode, SkillLink>(links).id((d) => d.id).distance(linkDist))
                .force("charge", d3.forceManyBody().strength(chargeStr))
                .force("center", d3.forceCenter(width / 2, height / 2))
                .force("collide", d3.forceCollide<SkillNode>().radius((d) => d.value * nodeScale + 12));

            // Drag behavior
            const drag = (sim: d3.Simulation<SkillNode, undefined>) => {
                function dragstarted(event: any) {
                    if (!event.active) sim.alphaTarget(0.3).restart();
                    event.subject.fx = event.subject.x;
                    event.subject.fy = event.subject.y;
                    canvas.style.cursor = 'grabbing';
                }
                
                function dragged(event: any) {
                    event.subject.fx = event.x;
                    event.subject.fy = event.y;
                }
                
                function dragended(event: any) {
                    if (!event.active) sim.alphaTarget(0);
                    event.subject.fx = null;
                    event.subject.fy = null;
                    canvas.style.cursor = 'grab';
                }
                
                return d3.drag<HTMLCanvasElement, SkillNode>()
                    .subject((event) => {
                        const [x, y] = [event.x, event.y];
                        let subject = null;
                        let distance = Infinity;
                        for (const node of nodes) {
                            const dist = Math.sqrt((x - node.x!) ** 2 + (y - node.y!) ** 2);
                            if (dist < distance && dist < 35) {
                                distance = dist;
                                subject = node;
                            }
                        }
                        return subject as any;
                    })
                    .on("start", dragstarted)
                    .on("drag", dragged)
                    .on("end", dragended);
            };

            d3.select(canvas).call(drag(simulation as any) as any);

            let hoverNode: SkillNode | null = null;

            // Element references for Left/Right panel synchronization
            const defaultView = document.getElementById('skill-default-view');
            const activeView = document.getElementById('skill-active-view');
            const activeCategory = document.getElementById('active-category');
            const activeTitle = document.getElementById('active-title');
            const activeProject = document.getElementById('active-project');
            const activeMetrics = document.getElementById('active-metrics');
            const activeDesc = document.getElementById('active-desc');

            d3.select(canvas).on("mousemove", (event) => {
                const [mouseX, mouseY] = d3.pointer(event);
                
                let prevHover = hoverNode;
                hoverNode = null;
                
                for (const node of nodes) {
                    const dist = Math.sqrt((mouseX - node.x!) ** 2 + (mouseY - node.y!) ** 2);
                    if (dist < node.value * nodeScale + 8) {
                        hoverNode = node;
                        break;
                    }
                }

                if (hoverNode !== prevHover) {
                    canvas.style.cursor = hoverNode ? 'pointer' : 'default';
                    
                    if (hoverNode) {
                        // Activate Active Intel Panel
                        if (defaultView) defaultView.classList.remove('active');
                        if (activeView) activeView.classList.add('active');

                        if (activeCategory) activeCategory.textContent = hoverNode.category || 'Integration';
                        if (activeTitle) activeTitle.textContent = hoverNode.id;
                        if (activeProject) activeProject.textContent = hoverNode.project || 'Mad EZ Fleet';
                        if (activeMetrics) activeMetrics.textContent = hoverNode.metrics || 'Verified';
                        if (activeDesc) activeDesc.textContent = hoverNode.desc || '';

                        // Color badge according to its category node
                        if (activeCategory) {
                            const colors = ['#00B9F1', '#E5007D', '#FCDC00', '#2d4a3e'];
                            const groupColor = colors[hoverNode.group - 1] || '#2d4a3e';
                            activeCategory.style.borderColor = groupColor;
                            activeCategory.style.color = groupColor;
                            activeCategory.style.backgroundColor = `${groupColor}0a`;
                        }
                    } else {
                        // Fallback to overview
                        if (defaultView) defaultView.classList.add('active');
                        if (activeView) activeView.classList.remove('active');
                    }
                }
                
                if (hoverNode) restart();
            });

            function restart() {
                if (!context) return;
                context.clearRect(0, 0, width, height);
                
                // Draw links (default alpha)
                context.save();
                context.globalAlpha = 0.08;
                context.strokeStyle = "#2d4a3e";
                context.lineWidth = 1;
                context.beginPath();
                links.forEach((link) => {
                    const s = link.source as SkillNode;
                    const t = link.target as SkillNode;
                    context.moveTo(s.x!, s.y!);
                    context.lineTo(t.x!, t.y!);
                });
                context.stroke();
                context.restore();

                // Highlight connections on hover
                if (hoverNode) {
                    context.save();
                    context.strokeStyle = colorScale(String(hoverNode.group));
                    context.globalAlpha = 0.5;
                    context.lineWidth = 2;
                    context.beginPath();
                    links.forEach((link) => {
                        const s = link.source as SkillNode;
                        const t = link.target as SkillNode;
                        if (s.id === hoverNode!.id || t.id === hoverNode!.id) {
                            context.moveTo(s.x!, s.y!);
                            context.lineTo(t.x!, t.y!);
                        }
                    });
                    context.stroke();
                    context.restore();
                }

                // Draw nodes
                nodes.forEach((node) => {
                    context.beginPath();
                    const radius = node.value * nodeScale;
                    const isHovered = hoverNode === node;
                    
                    const isConnected = hoverNode && links.some((l) => {
                        const s = l.source as SkillNode;
                        const t = l.target as SkillNode;
                        return (s.id === hoverNode!.id && t.id === node.id) ||
                               (t.id === hoverNode!.id && s.id === node.id);
                    });

                    const pulse = Math.sin(Date.now() / 800 + node.index!) * 0.6;
                    const finalRadius = isHovered ? radius + 4 : radius + pulse;

                    context.arc(node.x!, node.y!, finalRadius, 0, 2 * Math.PI);
                    context.fillStyle = colorScale(String(node.group));
                    
                    context.save();
                    if (isHovered) {
                        context.shadowBlur = 16;
                        context.shadowColor = colorScale(String(node.group));
                    } else if (isConnected) {
                        context.shadowBlur = 8;
                        context.shadowColor = colorScale(String(node.group));
                    } else {
                        context.shadowBlur = 0;
                    }
                    
                    context.fill();
                    context.restore();
                    context.strokeStyle = "#faf9f5";
                    context.lineWidth = 1.5;
                    context.stroke();

                    // Render titles legibly
                    context.fillStyle = "#2d4a3e";
                    context.font = `${isHovered ? '700 ' : '500 '}${fontSize}px 'JetBrains Mono', monospace`;
                    context.textAlign = "center";
                    context.textBaseline = "middle";
                    
                    if (node.value > 11 || isHovered || isConnected) {
                        context.fillText(node.id, node.x!, node.y! + finalRadius + 14);
                    }
                    
                    if (node.icon) {
                         context.font = `${node.value * 1.1}px Arial`;
                         context.fillText(node.icon, node.x!, node.y!);
                    }
                });
            }

            d3.timer(restart);

            // Resizing handler
            window.addEventListener('resize', () => {
                width = container.clientWidth || Math.min(window.innerWidth - 48, 800);
                height = (window.innerWidth <= 768) ? 380 : 500;
                
                const s = window.devicePixelRatio || 1;
                canvas.width = width * s;
                canvas.height = height * s;
                canvas.style.width = `${width}px`;
                canvas.style.height = `${height}px`;
                
                const ctx = canvas.getContext('2d');
                if (ctx) ctx.scale(s, s);
                
                simulation.force("center", d3.forceCenter(width / 2, height / 2));
                simulation.alpha(0.3).restart();
            });
        }
    }
</script>

<style define:vars={{
     transitionDuration: `${UX_CONFIG.TRANSITION_DURATION}ms`
}}>
    .skills-section-wrapper {
        width: 100%;
    }

    .home-eyebrow {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .22em;
        color: var(--accent-pink, #E5007D);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
    }

    .home-eyebrow .num {
        opacity: 0.8;
    }

    .section-title {
        font-family: "Playfair Display", serif;
        font-size: clamp(32px, 4.5vw, 56px);
        font-weight: 900;
        line-height: 1.1;
        color: #2d4a3e;
        margin: 0;
        letter-spacing: -0.025em;
    }

    .em-gradient {
        font-style: italic;
        background: linear-gradient(90deg, #00B9F1 0, #E5007D 100%);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
        -webkit-text-fill-color: transparent;
    }

    .section-subtitle {
        font-family: "Outfit", sans-serif;
        font-size: 1.1rem;
        color: rgba(45, 74, 62, 0.75);
        line-height: 1.6;
    }

    .skills-interactive-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 1024px) {
        .skills-interactive-grid {
            grid-template-columns: 3fr 2fr;
            align-items: stretch;
        }
    }

    /* Interactive Graph Canvas Panel */
    .canvas-panel {
        position: relative;
        width: 100%;
        background: radial-gradient(circle at center, #faf9f5 0%, #f5f4ed 100%);
        border-radius: 14px;
        border: 1px solid rgba(45, 74, 62, 0.1);
        overflow: hidden;
        cursor: grab;
        transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.32s;
        box-shadow: 0 8px 24px rgba(45, 74, 62, 0.04);
        min-height: 380px;
    }

    .canvas-panel:active {
        cursor: grabbing;
    }

    .canvas-panel:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 36px rgba(45, 74, 62, 0.07);
    }

    #skills-canvas {
        display: block;
        width: 100%;
    }

    .overlay-instruction {
        position: absolute;
        bottom: 0.75rem;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(45, 74, 62, 0.4);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.65rem;
        pointer-events: none;
        letter-spacing: 0.05em;
        white-space: nowrap;
        text-transform: uppercase;
    }

    /* Dynamic Details Panel */
    .details-panel {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid rgba(45, 74, 62, 0.08);
        padding: 2.25rem;
        box-shadow: 0 8px 24px rgba(45, 74, 62, 0.03);
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 300px;
        position: relative;
        overflow: hidden;
        border-top: 5px solid #2d4a3e;
    }

    .skill-detail-view {
        display: none;
        opacity: 0;
        transition: opacity 0.3s ease;
        flex-direction: column;
        gap: 1.5rem;
        height: 100%;
        justify-content: center;
    }

    .skill-detail-view.active {
        display: flex;
        opacity: 1;
    }

    .intel-header {
        border-bottom: 1px solid rgba(45, 74, 62, 0.1);
        padding-bottom: 1rem;
    }

    .intel-badge {
        display: inline-block;
        font-family: "JetBrains Mono", monospace;
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        padding: 3px 8px;
        border-radius: 4px;
        border: 1px solid rgba(45, 74, 62, 0.4);
        color: rgba(45, 74, 62, 0.7);
        margin-bottom: 0.75rem;
        background: rgba(45, 74, 62, 0.03);
        transition: all 0.25s ease;
    }

    .intel-title {
        font-family: "Playfair Display", serif;
        font-size: 1.8rem;
        font-weight: 850;
        color: #2d4a3e;
        margin: 0;
        letter-spacing: -0.01em;
    }

    .intel-body {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .intel-desc {
        font-family: "Outfit", sans-serif;
        font-size: 0.95rem;
        line-height: 1.6;
        color: rgba(45, 74, 62, 0.8);
        margin: 0;
    }

    /* Table styles for overview stats */
    .overview-stats {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-top: 0.5rem;
    }

    .stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 0.5rem;
        border-bottom: 1px dashed rgba(45, 74, 62, 0.1);
    }

    .stat-label {
        font-family: "Outfit", sans-serif;
        font-size: 0.85rem;
        color: rgba(45, 74, 62, 0.6);
    }

    .stat-value {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.85rem;
        font-weight: 600;
        color: #2d4a3e;
    }

    /* Meta items for active views */
    .intel-meta-item {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .meta-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 9.5px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(45, 74, 62, 0.45);
