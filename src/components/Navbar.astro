---
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const navLinks = [
    { name: 'Summary', href: isHome ? '#summary' : '/#summary', id: '01' },
    { name: 'Skills', href: isHome ? '#capabilities' : '/#capabilities', id: '02' },
    { name: 'AI Kit', href: '/starter-kit', id: '03' },
    { name: 'Intel', href: isHome ? '#intel' : '/#intel', id: '04' },
    { name: 'Resume', href: '/resume', id: '05' }
];

const ctaHref = isHome ? '#contact' : '/#contact';
---

<nav class="fixed top-0 left-0 w-full z-50 bg-background/85 backdrop-blur-md border-b border-foreground/10 px-6 md:px-[60px] py-4 md:py-5 flex justify-between items-center transition-all duration-300">
    <!-- Logo -->
    <a class="flex items-center gap-1 text-2xl font-black text-foreground no-underline" aria-label="Mikey Shaw — Home" href="/">
        <span class="font-display font-bold italic tracking-tight">mikey <span class="text-accent-pink">shaw</span></span>
    </a>

    <!-- Desktop Navigation Menu -->
    <div class="hidden md:flex gap-10 items-center">
        {navLinks.map((link) => (
            <a 
                class="font-label-mono text-[11px] font-semibold uppercase tracking-[0.25em] text-foreground/80 hover:text-accent-pink transition-colors no-underline cursor-pointer" 
                href={link.href}
                data-nav-link
            >
                {link.id} {link.name}
            </a>
        ))}
        <a 
            class="bg-foreground text-background px-6 py-2.5 font-sans font-bold text-xs uppercase tracking-widest hover:bg-foreground/90 hover:-translate-y-[1px] active:translate-y-0 transition-all rounded-full no-underline shadow-sm" 
            href={ctaHref}
        >
            Schedule Call
        </a>
    </div>

    <!-- Mobile Navigation Toggle -->
    <button 
        class="md:hidden flex flex-col justify-center items-end gap-1.5 w-8 h-8 bg-transparent border-none cursor-pointer z-55" 
        id="mobile-menu-toggle"
        aria-label="Toggle Navigation Menu"
        aria-expanded="false"
    >
        <span class="w-6 h-0.5 bg-foreground transition-transform duration-300 origin-center" id="bar-1"></span>
        <span class="w-4 h-0.5 bg-foreground transition-opacity duration-300" id="bar-2"></span>
        <span class="w-5 h-0.5 bg-foreground transition-transform duration-300 origin-center" id="bar-3"></span>
    </button>
</nav>

<!-- Mobile Drawer Overlay (Relocated outside <nav> to prevent z-index constraint) -->
<div 
    class="fixed inset-0 bg-background/98 z-54 md:hidden flex flex-col justify-center px-12 transition-all duration-500 opacity-0 pointer-events-none invisible" 
    id="mobile-drawer"
    role="dialog" 
    aria-modal="true" 
    aria-label="Navigation Menu"
>
    <div class="flex flex-col gap-8">
        {navLinks.map((link) => (
            <a 
                class="font-display text-4xl font-extrabold text-foreground hover:text-accent-pink no-underline transition-colors block" 
                href={link.href}
                data-mobile-nav-link
            >
                <span class="font-label-mono text-[13px] text-accent-pink tracking-widest mr-4 font-normal">{link.id}</span>
                {link.name}
            </a>
        ))}
        <div class="h-[1px] bg-foreground/10 w-full my-4"></div>
        <a 
            class="inline-block text-center bg-foreground text-background py-4 font-sans font-bold text-sm uppercase tracking-widest hover:bg-foreground/90 transition-all rounded-full no-underline shadow-md" 
            href={ctaHref}
            data-mobile-nav-link
        >
            Schedule Call
        </a>
    </div>
</div>

<script>
    function initNavbar() {
        const toggleBtn = document.getElementById('mobile-menu-toggle');
        const drawer = document.getElementById('mobile-drawer');
        const bar1 = document.getElementById('bar-1');
        const bar2 = document.getElementById('bar-2');
        const bar3 = document.getElementById('bar-3');
        const mobileLinks = document.querySelectorAll('[data-mobile-nav-link]');
        const desktopLinks = document.querySelectorAll('[data-nav-link]');

        if (!toggleBtn || !drawer) return;

        let isOpen = false;

        function toggleMenu() {
            isOpen = !isOpen;
            toggleBtn?.setAttribute('aria-expanded', String(isOpen));
            
            if (isOpen) {
                // Show Drawer
                drawer?.classList.remove('pointer-events-none', 'invisible');
                drawer?.classList.add('opacity-100', 'visible');
                
                // Animate Hamburger to 'X'
                if (bar1) {
                    bar1.style.transform = 'translateY(7px) rotate(45deg)';
                    bar1.style.width = '24px';
                }
                if (bar2) bar2.style.opacity = '0';
                if (bar3) {
                    bar3.style.transform = 'translateY(-7px) rotate(-45deg)';
                    bar3.style.width = '24px';
                }
            } else {
                // Hide Drawer
                drawer?.classList.add('pointer-events-none', 'invisible');
                drawer?.classList.remove('opacity-100', 'visible');
                
                // Animate 'X' back to Hamburger
                if (bar1) {
                    bar1.style.transform = 'none';
                    bar1.style.width = '24px';
                }
                if (bar2) bar2.style.opacity = '1';
                if (bar3) {
                    bar3.style.transform = 'none';
                    bar3.style.width = '20px';
                }
            }
        }

        toggleBtn.addEventListener('click', toggleMenu);

        // Close drawer on link clicks
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                if (isOpen) toggleMenu();
            });
        });

        // Smooth scroll for hash links on the same page
        function smoothScroll(e: Event) {
            const currentTarget = e.currentTarget as HTMLAnchorElement;
            const href = currentTarget.getAttribute('href') || '';
            
            // Check if it's a hash link for the current page
            if (href.startsWith('#')) {
                e.preventDefault();
                const targetEl = document.querySelector(href);
                if (targetEl) {
                    targetEl.scrollIntoView({ behavior: 'smooth' });
                }
            } else if (href.startsWith('/#')) {
                // If on homepage, strip the '/' and smooth scroll
                if (window.location.pathname === '/' || window.location.pathname === '') {
                    e.preventDefault();
                    const hash = href.substring(1);
                    const targetEl = document.querySelector(hash);
                    if (targetEl) {
                        targetEl.scrollIntoView({ behavior: 'smooth' });
                    }
                }
            }
        }

        desktopLinks.forEach(link => link.addEventListener('click', smoothScroll));
        mobileLinks.forEach(link => link.addEventListener('click', smoothScroll));
    }

    // Initialize
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initNavbar);
    } else {
        initNavbar();
    }
    
    // Support Astro View Transitions
    document.addEventListener('astro:page-load', initNavbar);
</script>
