---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Scene3D from '../components/Scene3D.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
import SkillsVisualization from '../components/SkillsVisualization.astro';
import GitHubStats from '../components/GitHubStats.astro';
import CompanyProfile from '../components/CompanyProfile.astro';
import DesiredProjects from '../components/DesiredProjects.astro';
import ContactSection from '../components/ContactSection.astro';
import BlogFeed from '../components/BlogFeed.astro';
import { ChatWidget } from '../components/ChatWidget';
import mikeyShaw from '../images/mikey-shaw.png';
import ServicesAndOffers from '../components/ServicesAndOffers.tsx';
---

<Layout title="Mikey Shaw | Digital Architect — AI Systems for Operators">
    <!-- Sticky Shared Navigation -->
    <Navbar />

    <!-- 3D Interactive Layer -->
    <Scene3D shapeCount={50} complexity={0.9} theme="light" />

    <main class="w-full">
        <!-- Modern Hero Section -->
        <section class="min-h-screen editorial-grid pt-36 relative overflow-hidden" id="hero">
            <div class="overlap-1 flex flex-col justify-center reveal-item opacity-0">
                <span class="font-label-mono text-accent-pink mb-4 tracking-[0.4em] uppercase text-xs font-semibold">N° 01 • THE STUDIO</span>
                <h1 class="font-display-xl text-[5.5vw] md:text-[4.2vw] leading-[1.05] font-black tracking-tight text-[#2d4a3e]">
                    Stop managing AI tools. <br/><em class="em-gradient font-black">Start running AI systems.</em>
                </h1>
                <p class="font-body-md text-lg text-[#2d4a3e]/85 max-w-xl mt-8 leading-relaxed">
                    I help operators, executives, and sales professionals build AI that remembers their business — using the ACMI framework (Profile / Signals / Timeline) so nothing falls through the cracks.
                </p>
                <div class="flex flex-wrap gap-4 items-center mt-10">
                    <a class="bg-[#2d4a3e] text-white px-8 py-4 font-bold text-xs uppercase tracking-widest hover:bg-[#3a5c4e] transition-all rounded-full no-underline" href="/starter-kit">Get the Free ACMI Starter Kit →</a>
                    <a class="bg-[#E5007D] text-white px-8 py-4 font-bold text-xs uppercase tracking-widest hover:bg-[#c4006a] transition-all rounded-full no-underline" href="#contact">Book a Strategy Call</a>
                </div>
            </div>
            
            <div class="overlap-2 relative reveal-item opacity-0 flex items-center justify-center">
                <div class="relative w-full max-w-lg">
                    <Image 
                        src={mikeyShaw}
                        alt="Mikey Shaw" 
                        class="w-full h-[550px] object-cover grayscale contrast-115 brightness-95 hover:grayscale-0 transition-all duration-700 rounded-2xl border border-[#2d4a3e]/10 shadow-md" 
                        width={800}
                        height={600}
                        format="avif"
                        quality="high"
                        loading="eager"
                    />
                    <div class="absolute -bottom-6 -left-6 p-6 bg-white/95 backdrop-blur-md text-[#2d4a3e] max-w-xs rounded-xl border border-[#2d4a3e]/10 shadow-lg">
                        <p class="font-headline-md leading-tight font-bold text-sm">
                            "If it requires manual button clicks, it is an operational liability."
                        </p>
                        <span class="font-label-mono text-[9px] uppercase tracking-wider text-accent-pink mt-2 block">— Execution Philosophy</span>
                    </div>
                </div>
            </div>

            <!-- Vertical Text Decorative -->
            <div class="absolute right-10 top-1/2 -translate-y-1/2 text-vertical font-label-mono text-[10px] tracking-[1em] opacity-35 uppercase hidden lg:block text-primary">
                Autonomous Systems • Technical Leadership • Persistent Protocols
            </div>
        </section>

        <!-- Asymmetrical Summary (Approach) -->
        <section class="px-6 md:px-[60px] py-28 grid grid-cols-12 gap-8 md:gap-12 relative" id="summary">
            <div class="col-span-12 md:col-span-5 relative">
                <div class="absolute -top-20 -left-10 text-[20rem] font-black opacity-[0.02] text-primary select-none pointer-events-none">01</div>
                <div class="home-eyebrow"><span class="num">N° 02</span>The Method</div>
                <h2 class="font-headline-lg text-5xl uppercase font-black mb-8 leading-none reveal-item opacity-0 text-primary">Philosophy of Execution.</h2>
                <p class="font-body-lg text-xl leading-relaxed mb-8 border-l-4 border-accent-pink pl-6 reveal-item opacity-0 text-primary">
                    I don't build playground prototypes. I build production-grade automation systems designed for speed, scale, and operational reliability.
                </p>
            </div>
            
            <div class="col-span-12 md:col-span-7 flex flex-col justify-end">
                <p class="font-body-md text-base max-w-xl mb-12 text-primary/75 reveal-item opacity-0 leading-relaxed">
                    My engineering process is structured in three movements. We Architect the data flow and agent schemas; we Build using Next.js 16, Supabase, and Upstash Redis; and we Operate the pipelines on automated cron loops backed by ACMI.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 reveal-item opacity-0">
                    <div class="bg-white border border-[#2d4a3e]/10 p-6 flex flex-col justify-between hover:border-[#2d4a3e]/30 transition-all rounded-xl shadow-sm hover:translate-y-[-2px]">
                        <div>
                            <span class="material-symbols-outlined text-3xl text-accent-cyan" data-icon="schema">schema</span>
                            <h4 class="font-sans font-bold text-sm uppercase tracking-wider text-[#2d4a3e] mt-4 mb-2">01. Architect</h4>
                        </div>
                        <p class="font-sans text-xs text-[#2d4a3e]/70 leading-relaxed">Modeling data schemas, agent behaviors, and state-locked generation references before writing code.</p>
                    </div>
                    <div class="bg-white border border-[#2d4a3e]/10 p-6 flex flex-col justify-between hover:border-[#2d4a3e]/30 transition-all rounded-xl shadow-sm hover:translate-y-[-2px]">
                        <div>
                            <span class="material-symbols-outlined text-3xl text-accent-pink" data-icon="code">code</span>
                            <h4 class="font-sans font-bold text-sm uppercase tracking-wider text-[#2d4a3e] mt-4 mb-2">02. Build</h4>
                        </div>
                        <p class="font-sans text-xs text-[#2d4a3e]/70 leading-relaxed">Shipping TypeScript codebases with Supabase Postgres and Redis caching for sub-10ms response times.</p>
                    </div>
                    <div class="bg-white border border-[#2d4a3e]/10 p-6 flex flex-col justify-between hover:border-[#2d4a3e]/30 transition-all rounded-xl shadow-sm hover:translate-y-[-2px]">
                        <div>
                            <span class="material-symbols-outlined text-3xl text-accent-yellow" data-icon="sync_alt">sync_alt</span>
                            <h4 class="font-sans font-bold text-sm uppercase tracking-wider text-[#2d4a3e] mt-4 mb-2">03. Operate</h4>
                        </div>
                        <p class="font-sans text-xs text-[#2d4a3e]/70 leading-relaxed">Running pipelines on automated loops via launchd, monitored with real-time ACMI event logs.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Company Profile (Astro Component) -->
        <section class="w-full">
            <div class="reveal-item opacity-0">
                <CompanyProfile />
            </div>
        </section>

        <!-- Desired Projects & Market Target -->
        <section class="w-full">
            <div class="reveal-item opacity-0">
                <DesiredProjects />
            </div>
        </section>

        <!-- Capabilities Horizontal Strip -->
        <section class="bg-[#2d4a3e] py-24 px-6 md:px-[60px] overflow-hidden relative" id="capabilities">
            <div class="absolute top-0 right-0 p-4 font-label-mono text-[15rem] leading-none opacity-[0.03] text-white font-black select-none pointer-events-none">03</div>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 relative z-10">
                <div class="group reveal-item opacity-0">
                    <div class="text-accent-cyan font-black text-4xl mb-4">01</div>
                    <h3 class="font-headline-md text-white uppercase font-bold mb-4">Autonomous Media</h3>
                    <p class="font-body-md text-white/75 text-sm leading-relaxed">Integrating Fal.ai, RunPod InfiniteTalk, and Deepgram voice models to generate consistent talking-head content on autopilot.</p>
                </div>
                <div class="group reveal-item opacity-0">
                    <div class="text-accent-pink font-black text-4xl mb-4">02</div>
                    <h3 class="font-headline-md text-white uppercase font-bold mb-4">Agentic Memory (ACMI)</h3>
                    <p class="font-body-md text-white/75 text-sm leading-relaxed">Deploying the ACMI memory bus protocol to provide agents with Profile, Signals, and Timeline persistence slots.</p>
                </div>
                <div class="group reveal-item opacity-0">
                    <div class="text-accent-yellow font-black text-4xl mb-4">03</div>
                    <h3 class="font-headline-md text-white uppercase font-bold mb-4">Database Modernization</h3>
                    <p class="font-body-md text-white/75 text-sm leading-relaxed">Upgrading legacy database layers to Supabase PostgreSQL, implementing Redis TTL cache routing for &lt;10ms responses.</p>
                </div>
                <div class="group reveal-item opacity-0">
                    <div class="text-white font-black text-4xl mb-4">04</div>
                    <h3 class="font-headline-md text-white uppercase font-bold mb-4">Lead Discovery Engines</h3>
                    <p class="font-body-md text-white/75 text-sm leading-relaxed">Building geo-targeted crawlers (Places/Yelp) that calculate API costs, analyze tech gaps, and qualify prospects.</p>
                </div>
            </div>
        </section>

        <!-- Dynamic Skills Visualization -->
        <section class="px-6 md:px-[60px] py-24 bg-surface-container border-y border-primary/10">
            <div class="max-w-[1440px] mx-auto">
                <h3 class="font-label-mono text-accent-pink tracking-[0.5em] uppercase text-xs mb-8">System Engineering</h3>
                <h2 class="font-headline-lg text-5xl uppercase font-black text-primary mb-16">Interactive Skills Architecture</h2>
                <div>
                    <SkillsVisualization />
                </div>
            </div>
        </section>


        <!-- GitHub Integration & Performance Metrics -->
        <section class="px-6 md:px-[60px] py-24 bg-surface-container border-y border-primary/10">
            <div class="max-w-[1440px] mx-auto">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                    <div class="lg:col-span-4 flex flex-col justify-center reveal-item opacity-0">
                        <span class="font-label-mono text-accent-cyan text-xs uppercase tracking-[0.4em] mb-4">Telemetry</span>
                        <h2 class="font-headline-lg text-4xl font-black uppercase leading-none mb-6 text-primary">Open Design &amp; Engine Output</h2>
                        <p class="font-body-md text-primary/75">
                            Live system activity, codebase statistics, and recent commit volumes across our core repositories.
                        </p>
                    </div>
                    <div class="lg:col-span-8 reveal-item opacity-0">
                        <GitHubStats />
                    </div>
                </div>
            </div>
        </section>

        <!-- Services, Offers & Whop Tiers Section -->
        <section class="px-6 md:px-[60px] py-24 bg-[#faf9f5] border-t border-primary/10" id="services">
            <div class="max-w-[1440px] mx-auto reveal-item opacity-0">
                <div class="flex items-baseline gap-8 mb-8">
                    <h2 class="font-display-xl text-7xl md:text-8xl font-black tracking-tighter uppercase leading-none text-primary">Services</h2>
                    <span class="font-label-mono text-accent-pink tracking-[0.5em] uppercase text-xs">03 Offerings</span>
                </div>
                
                <p class="font-body-lg text-lg text-primary/70 mb-16 max-w-2xl">
                    High-end B2B autonomous systems deployment, strategic AI coaching for executives, and direct Whop developer suite access.
                </p>

                <ServicesAndOffers client:load />
            </div>
        </section>

        <!-- Blog Feed & Outreach -->
        <section class="px-6 md:px-[60px] py-24 bg-surface-container border-y border-primary/10" id="intel">
            <div class="max-w-[1440px] mx-auto reveal-item opacity-0">
                <BlogFeed />
            </div>
        </section>

        <!-- Interactive Contact Form -->
        <section class="px-6 md:px-[60px] py-24 bg-surface-container">
            <div class="max-w-[1440px] mx-auto reveal-item opacity-0">
                <ContactSection />
            </div>
        </section>
    </main>

    <!-- Radical Footer -->
    <footer class="px-6 md:px-[60px] py-12 border-t border-primary/10 flex flex-col md:flex-row justify-between items-center gap-8 bg-surface-container text-primary">
        <div class="font-headline-lg text-4xl font-black">MS<span class="text-primary/40">.</span></div>
        <div class="flex gap-12 font-label-mono text-[10px] tracking-widest uppercase">
            <a class="hover:text-primary/60 transition-colors" href="#">Privacy</a>
            <a class="hover:text-primary/60 transition-colors" href="#">Terms</a>
            <a class="hover:text-primary/60 transition-colors" href="#">Guidelines</a>
        </div>
        <div class="font-label-mono text-[9px] opacity-40 uppercase tracking-[0.3em]">
            © 2026 CREATIVE TECHNOLOGIST STUDIO. ALL RIGHTS RESERVED.
        </div>
    </footer>
</Layout>
