---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Mikey Shaw → Core Pumping Solutions | Employment Proposal">
    <Navbar />
    
    <main class="proposal-page">
        <!-- HERO -->
        <section class="proposal-hero">
            <div class="hero-badge">EMPLOYMENT PROPOSAL</div>
            <h1 class="hero-title">
                Michael Shaw<span class="gold">.</span>
                <span class="subtitle">Dispatcher & Systems Architect</span>
            </h1>
            <p class="hero-subtitle">Prepared for <strong>Core Pumping Solutions</strong> — April 2026</p>
            <div class="hero-divider"></div>
            <p class="hero-tagline">
                I don't just dispatch trucks.<br>
                I build the system that makes dispatching <em>effortless</em>.
            </p>
        </section>

        <!-- THE PROPOSITION -->
        <section class="proposal-section">
            <div class="section-label">THE PROPOSITION</div>
            <h2 class="section-title">Hire Me for 2 Weeks.</h2>
            <p class="section-body">
                If I can't handle the pressure, the pace, and the chaos of dispatching your fleet — 
                shake my hand and tell me to go. No hard feelings.
            </p>
            <p class="section-body">
                But if I can, you're not just getting a dispatcher. You're getting someone who will 
                <strong>learn your operation</strong>, <strong>earn your trust</strong>, and then 
                <strong>build systems</strong> that make every week smoother than the last.
            </p>
            <div class="value-cards">
                <div class="value-card">
                    <div class="value-icon">⚡</div>
                    <h3>Immediate Value</h3>
                    <p>Show up, learn the process, dispatch trucks from Day 1. No tech, no changes — just hustle.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">🧠</div>
                    <h3>Systems Thinking</h3>
                    <p>20+ years building operational systems. I see bottlenecks before they become problems.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">🚀</div>
                    <h3>Scalable Growth</h3>
                    <p>As Core grows from 5 trucks to 15 across two states — I build the systems that grow with you.</p>
                </div>
            </div>
        </section>

        <!-- WHO I AM -->
        <section class="proposal-section alt-bg">
            <div class="section-label">WHO I AM</div>
            <h2 class="section-title">Michael Shaw — At a Glance</h2>
            
            <div class="profile-grid">
                <div class="profile-stats">
                    <div class="stat">
                        <span class="stat-number">20+</span>
                        <span class="stat-label">Years Building Systems</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">6</span>
                        <span class="stat-label">AI Companies Founded</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">30+</span>
                        <span class="stat-label">Technologies Mastered</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">24/7</span>
                        <span class="stat-label">Commitment Level</span>
                    </div>
                </div>
                
                <div class="profile-details">
                    <div class="detail-item">
                        <span class="detail-label">Company</span>
                        <span class="detail-value">Mad EZ Media Partners — Founder & CEO</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Specialization</span>
                        <span class="detail-value">AI Automation & Operations Systems</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Core Skill</span>
                        <span class="detail-value">Walking into chaos and building order</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Tech Stack</span>
                        <span class="detail-value">Full-stack development, AI integration, real-time systems</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Location</span>
                        <span class="detail-value">Charlotte, NC area (Harrisburg adjacent)</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- THE 90-DAY PLAN -->
        <section class="proposal-section">
            <div class="section-label">THE 90-DAY PLAN</div>
            <h2 class="section-title">How I'll Deliver Value Every Month</h2>
            
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-marker">1</div>
                    <div class="timeline-content">
                        <h3>Days 1-14 <span class="gold">// Learn & Execute</span></h3>
                        <ul>
                            <li>Shadow the current dispatch process — no changes, no tech</li>
                            <li>Learn every truck, every driver, every regular customer</li>
                            <li>Take incoming calls and book jobs alongside whoever does it now</li>
                            <li>Map every bottleneck: Where does time get lost? What falls through the cracks?</li>
                            <li><strong>Goal:</strong> Handle the daily dispatch independently</li>
                        </ul>
                    </div>
                </div>
                
                <div class="timeline-item">
                    <div class="timeline-marker">2</div>
                    <div class="timeline-content">
                        <h3>Days 15-30 <span class="gold">// Optimize</span></h3>
                        <ul>
                            <li>Build a visual dispatch dashboard — every truck, every job, one screen</li>
                            <li>Set up automated driver assignment texts (job details + GPS link, one tap)</li>
                            <li>Create customer confirmation/ETA notification system</li>
                            <li>Build end-of-day report that auto-generates from the day's data</li>
                            <li><strong>Goal:</strong> The schedule is visible, communication is faster, nothing falls through</li>
                        </ul>
                    </div>
                </div>
                
                <div class="timeline-item">
                    <div class="timeline-marker">3</div>
                    <div class="timeline-content">
                        <h3>Days 31-90 <span class="gold">// Scale</span></h3>
                        <ul>
                            <li>AI schedule optimizer — suggests best truck for each job based on location, equipment, and operator</li>
                            <li>Smart re-routing — when a truck breaks down, system auto-suggests the closest replacement</li>
                            <li>Auto-invoicing pipeline — job done → invoice generated → sent to QuickBooks</li>
                            <li>Customer booking portal — contractors book online instead of calling at 5 PM Friday</li>
                            <li>Maintenance tracker — truck service reminders, repair history, downtime alerts</li>
                            <li><strong>Goal:</strong> Operations run so smooth you can focus 100% on growth</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- WHAT I BRING -->
        <section class="proposal-section alt-bg">
            <div class="section-label">SKILLS TRANSFER</div>
            <h2 class="section-title">What I Bring to Core Pumping</h2>
            
            <div class="skills-transfer">
                <div class="transfer-row">
                    <div class="transfer-need">Dispatch under pressure</div>
                    <div class="transfer-arrow">←</div>
                    <div class="transfer-have">Managed real-time AI systems where every second counts</div>
                </div>
                <div class="transfer-row">
                    <div class="transfer-need">Coordinate multiple trucks</div>
                    <div class="transfer-arrow">←</div>
                    <div class="transfer-have">Coordinated 8+ concurrent AI agents across multiple channels</div>
                </div>
                <div class="transfer-row">
                    <div class="transfer-need">Customer communication</div>
                    <div class="transfer-arrow">←</div>
                    <div class="transfer-have">20+ years client management across Slack, Telegram, email, phone</div>
                </div>
                <div class="transfer-row">
                    <div class="transfer-need">Quick problem solving</div>
                    <div class="transfer-arrow">←</div>
                    <div class="transfer-have">Production debugging — assess, prioritize, execute, prevent recurrence</div>
                </div>
                <div class="transfer-row">
                    <div class="transfer-need">Track job data & invoicing</div>
                    <div class="transfer-arrow">←</div>
                    <div class="transfer-have">Built automated reporting systems with real-time dashboards</div>
                </div>
                <div class="transfer-row">
                    <div class="transfer-need">Grow with the company</div>
                    <div class="transfer-arrow">←</div>
                    <div class="transfer-have">Founded 6 companies — I know what scaling looks like</div>
                </div>
            </div>
        </section>

        <!-- THE SYSTEM I'D BUILD -->
        <section class="proposal-section">
            <div class="section-label">THE TECHNOLOGY</div>
            <h2 class="section-title">The Dispatch System I'd Build for Core</h2>
            
            <div class="system-visual">
                <div class="system-box">
                    <div class="system-header">CORE DISPATCH SYSTEM</div>
                    <div class="system-grid">
                        <div class="system-module">
                            <div class="module-icon">📅</div>
                            <div class="module-name">Smart Schedule</div>
                            <div class="module-desc">Drag-and-drop calendar. Visual truck × day × job view.</div>
                        </div>
                        <div class="system-module">
                            <div class="module-icon">📍</div>
                            <div class="module-name">Live Tracking</div>
                            <div class="module-desc">GPS map showing every truck's location and status.</div>
                        </div>
                        <div class="system-module">
                            <div class="module-icon">🤖</div>
                            <div class="module-name">AI Optimizer</div>
                            <div class="module-desc">Auto-suggests best truck for each job. Handles re-routing.</div>
                        </div>
                        <div class="system-module">
                            <div class="module-icon">📱</div>
                            <div class="module-name">Auto Comms</div>
                            <div class="module-desc">Driver texts. Customer confirmations. ETA updates.</div>
                        </div>
                        <div class="system-module">
                            <div class="module-icon">💰</div>
                            <div class="module-name">Auto Invoice</div>
                            <div class="module-desc">Job done → ticket generated → invoice sent to QuickBooks.</div>
                        </div>
                        <div class="system-module">
                            <div class="module-icon">🔧</div>
                            <div class="module-name">Maintenance</div>
                            <div class="module-desc">Service reminders. Repair history. Downtime alerts.</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="tech-note">
                <strong>Built at zero cost to Core Pumping.</strong> 
                This is my value-add — I develop custom software as part of my role. 
                No monthly SaaS fees. No per-truck charges. Just systems that work.
            </div>
        </section>

        <!-- INDUSTRY KNOWLEDGE -->
        <section class="proposal-section alt-bg">
            <div class="section-label">I DID MY HOMEWORK</div>
            <h2 class="section-title">I Know This Industry</h2>
            <p class="section-body">
                I don't walk in blind. Here's what I've already researched about concrete pumping dispatch:
            </p>
            
            <div class="knowledge-grid">
                <div class="knowledge-item">
                    <h4>The Competition</h4>
                    <p>Brundage-Bone runs Charlotte with proper software and pays dispatchers $45-50K. CMP and Encore cover the region. Core is winning on hustle and relationships — I help match the big boys' tech without their price tag.</p>
                </div>
                <div class="knowledge-item">
                    <h4>The Software Landscape</h4>
                    <p>RapidWorks, PumpFLEET, CreteSuite, Scheduleflow — purpose-built tools that cost $200-500/month. I can build Core a custom system that does exactly what you need, nothing more, for free.</p>
                </div>
                <div class="knowledge-item">
                    <h4>The Lithko Relationship</h4>
                    <p>Your biggest client demands reliability. Every system I build protects and strengthens that account. Communication, on-time dispatch, and documentation — Lithko needs all three dialed in.</p>
                </div>
                <div class="knowledge-item">
                    <h4>The Multi-State Play</h4>
                    <p>Charlotte to Myrtle Beach means logistics complexity. Coordinating across NC and SC with a growing fleet requires systems that scale. That's literally what I build for a living.</p>
                </div>
            </div>
        </section>

        <!-- THE ASK -->
        <section class="proposal-section">
            <div class="section-label">THE ASK</div>
            <h2 class="section-title">What I'm Looking For</h2>
            
            <div class="ask-grid">
                <div class="ask-item">
                    <div class="ask-label">Role</div>
                    <div class="ask-value">Dispatcher + General Office Manager</div>
                </div>
                <div class="ask-item">
                    <div class="ask-label">Type</div>
                    <div class="ask-value">Contract to start, full-time when earned</div>
                </div>
                <div class="ask-item">
                    <div class="ask-label">Rate</div>
                    <div class="ask-value">$22-25/hr (competitive for Charlotte, reflects the systems I bring)</div>
                </div>
                <div class="ask-item">
                    <div class="ask-label">Hours</div>
                    <div class="ask-value">Whatever the operation requires — early mornings included</div>
                </div>
                <div class="ask-item">
                    <div class="ask-label">Start</div>
                    <div class="ask-value">Immediately</div>
                </div>
                <div class="ask-item">
                    <div class="ask-label">Trial</div>
                    <div class="ask-value">2 weeks — if I can't handle it, I walk. Zero risk to you.</div>
                </div>
            </div>
        </section>

        <!-- CLOSING -->
        <section class="proposal-section closing">
            <div class="closing-quote">
                "Every other applicant is just a dispatcher.<br>
                I'm a dispatcher who also builds the software<br>
                that makes dispatching easier."<br>
                <span class="closing-author">— Michael Shaw</span>
            </div>
            
            <div class="closing-cta">
                <div class="cta-links">
                    <a href="/" class="cta-button primary">View Full Portfolio</a>
                    <a href="tel:2023001442" class="cta-button secondary">Call Me: (202) 300-1442</a>
                </div>
                <p class="cta-note">Madezmedia@gmail.com • Charlotte, NC</p>
            </div>
        </section>
    </main>

    <style>
        .proposal-page {
            max-width: 900px;
            margin: 0 auto;
            padding: 120px 2rem 4rem;
        }

        /* HERO */
        .proposal-hero {
            text-align: center;
            margin-bottom: 4rem;
        }
        .hero-badge {
            display: inline-block;
            background: rgba(212, 175, 55, 0.15);
            border: 1px solid var(--primary-dark, #D4AF37);
            color: var(--primary-dark, #D4AF37);
            padding: 6px 20px;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.15em;
            margin-bottom: 2rem;
        }
        .hero-title {
            font-size: clamp(2.5rem, 6vw, 4rem);
            font-weight: 800;
            color: white;
            line-height: 1.1;
            margin-bottom: 0.5rem;
        }
        .gold { color: var(--primary-dark, #D4AF37); }
        .hero-title .subtitle {
            display: block;
            font-size: clamp(1rem, 2.5vw, 1.5rem);
            font-weight: 400;
            color: #aaa;
            margin-top: 0.5rem;
        }
        .hero-subtitle {
            color: #999;
            font-size: 1rem;
            margin: 1.5rem 0;
        }
        .hero-subtitle strong {
            color: var(--primary-dark, #D4AF37);
        }
        .hero-divider {
            width: 80px;
            height: 3px;
            background: var(--primary-dark, #D4AF37);
            margin: 2rem auto;
        }
        .hero-tagline {
            font-size: 1.25rem;
            color: #ccc;
            font-style: italic;
            line-height: 1.6;
        }

        /* SECTIONS */
        .proposal-section {
            margin-bottom: 4rem;
            padding: 3rem;
            border-radius: 12px;
        }
        .proposal-section.alt-bg {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
        }
        .section-label {
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            color: var(--primary-dark, #D4AF37);
            margin-bottom: 1rem;
        }
        .section-title {
            font-size: clamp(1.5rem, 3vw, 2rem);
            font-weight: 700;
            color: white;
            margin-bottom: 1.5rem;
        }
        .section-body {
            color: #bbb;
            font-size: 1.05rem;
            line-height: 1.7;
            margin-bottom: 1rem;
        }

        /* VALUE CARDS */
        .value-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }
        .value-card {
            background: rgba(212, 175, 55, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.15);
            border-radius: 10px;
            padding: 2rem 1.5rem;
            text-align: center;
        }
        .value-icon {
            font-size: 2rem;
            margin-bottom: 1rem;
        }
        .value-card h3 {
            color: white;
            font-size: 1.1rem;
            margin-bottom: 0.75rem;
        }
        .value-card p {
            color: #999;
            font-size: 0.9rem;
            line-height: 1.5;
        }

        /* PROFILE GRID */
        .profile-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-top: 2rem;
        }
        .profile-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }
        .stat {
            text-align: center;
            padding: 1.5rem;
            background: rgba(212, 175, 55, 0.05);
            border-radius: 10px;
        }
        .stat-number {
            display: block;
            font-size: 2rem;
            font-weight: 800;
            color: var(--primary-dark, #D4AF37);
        }
        .stat-label {
            display: block;
            font-size: 0.75rem;
            color: #999;
            margin-top: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .profile-details {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .detail-item {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .detail-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--primary-dark, #D4AF37);
            font-weight: 600;
        }
        .detail-value {
            color: #ddd;
            font-size: 0.95rem;
        }

        /* TIMELINE */
        .timeline {
            margin-top: 2rem;
        }
        .timeline-item {
            display: flex;
            gap: 1.5rem;
            margin-bottom: 2rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .timeline-item:last-child {
            border-bottom: none;
        }
        .timeline-marker {
            flex-shrink: 0;
            width: 48px;
            height: 48px;
            background: var(--primary-dark, #D4AF37);
            color: #121212;
            font-weight: 800;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }
        .timeline-content h3 {
            color: white;
            font-size: 1.1rem;
            margin-bottom: 0.75rem;
        }
        .timeline-content ul {
            list-style: none;
            padding: 0;
        }
        .timeline-content li {
            color: #bbb;
            font-size: 0.9rem;
            line-height: 1.6;
            padding-left: 1.25rem;
            position: relative;
            margin-bottom: 0.5rem;
        }
        .timeline-content li::before {
            content: '→';
            position: absolute;
            left: 0;
            color: var(--primary-dark, #D4AF37);
        }
        .timeline-content li strong {
            color: var(--primary-dark, #D4AF37);
        }

        /* SKILLS TRANSFER */
        .skills-transfer {
            margin-top: 2rem;
        }
        .transfer-row {
            display: grid;
            grid-template-columns: 1fr auto 2fr;
            gap: 1rem;
            align-items: center;
            padding: 1rem 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .transfer-need {
            color: white;
            font-weight: 600;
            font-size: 0.95rem;
            text-align: right;
        }
        .transfer-arrow {
            color: var(--primary-dark, #D4AF37);
            font-size: 1.5rem;
            text-align: center;
        }
        .transfer-have {
            color: #999;
            font-size: 0.9rem;
            line-height: 1.4;
        }

        /* SYSTEM VISUAL */
        .system-visual {
            margin-top: 2rem;
        }
        .system-box {
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: 12px;
            overflow: hidden;
        }
        .system-header {
            background: var(--primary-dark, #D4AF37);
            color: #121212;
            font-weight: 800;
            text-align: center;
            padding: 1rem;
            font-size: 0.85rem;
            letter-spacing: 0.15em;
        }
        .system-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 0;
        }
        .system-module {
            padding: 1.5rem;
            border-right: 1px solid rgba(212, 175, 55, 0.1);
            border-bottom: 1px solid rgba(212, 175, 55, 0.1);
            text-align: center;
        }
        .module-icon {
            font-size: 1.75rem;
            margin-bottom: 0.5rem;
        }
        .module-name {
            color: white;
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 0.4rem;
        }
        .module-desc {
            color: #888;
            font-size: 0.8rem;
            line-height: 1.4;
        }
        .tech-note {
            margin-top: 1.5rem;
            padding: 1rem 1.5rem;
            background: rgba(212, 175, 55, 0.08);
            border-left: 3px solid var(--primary-dark, #D4AF37);
            border-radius: 0 8px 8px 0;
            color: #ccc;
            font-size: 0.9rem;
        }

        /* KNOWLEDGE GRID */
        .knowledge-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-top: 2rem;
        }
        .knowledge-item {
            padding: 1.5rem;
            background: rgba(255,255,255,0.03);
            border-radius: 8px;
        }
        .knowledge-item h4 {
            color: var(--primary-dark, #D4AF37);
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }
        .knowledge-item p {
            color: #999;
            font-size: 0.85rem;
            line-height: 1.5;
        }

        /* ASK GRID */
        .ask-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-top: 2rem;
        }
        .ask-item {
            padding: 1.5rem;
            background: rgba(212, 175, 55, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.15);
            border-radius: 8px;
        }
        .ask-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--primary-dark, #D4AF37);
            font-weight: 600;
            margin-bottom: 0.4rem;
        }
        .ask-value {
            color: white;
            font-size: 1rem;
            font-weight: 500;
        }

        /* CLOSING */
        .closing {
            text-align: center;
            padding: 4rem 3rem;
        }
        .closing-quote {
            font-size: clamp(1.2rem, 2.5vw, 1.5rem);
            color: white;
            line-height: 1.6;
            font-style: italic;
            margin-bottom: 0.75rem;
        }
        .closing-author {
            display: block;
            color: var(--primary-dark, #D4AF37);
            font-style: normal;
            font-size: 1rem;
            margin-top: 1rem;
        }
        .closing-cta {
            margin-top: 3rem;
        }
        .cta-links {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }
        .cta-button {
            display: inline-block;
            padding: 14px 32px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 0.95rem;
            text-decoration: none;
